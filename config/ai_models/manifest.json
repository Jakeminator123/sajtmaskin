{
  "schemaVersion": 1,
  "title": "Sajtmaskin AI model registry",
  "description": "Single source for default model IDs, token budgets, and env override keys. Environment variables always win over these defaults when set.",
  "documentationDirectApiNote": "Länkar märkta appliesTo=direct_provider_api beskriver anrop direkt mot OpenAI (api.openai.com) respektive Anthropic (Claude API) — samma semantik som OpenAI SDK / Anthropic SDK mot standardbas-URL.",
