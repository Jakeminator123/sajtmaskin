    "next": "^16.1.4",
    "next-themes": "^0.4.6",
    "openai": "^6.16.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.17.2",
    "postcss": "^8.5.1",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.7.2",
    "react-syntax-highlighter": "^16.1.0",
    "recharts": "^2.15.4",
    "resend": "^6.9.1",
    "sonner": "^2.0.7",
    "streamdown": "^2.4.0",
    "stripe": "^20.2.0",
    "swr": "^2.3.8",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "three": "^0.183.2",
    "tokenlens": "^1.3.1",
    "typescript": "5.9.3",
    "v0-sdk": "^0.16.1",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jszip": "^3.4.0",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.0.10",
