{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "feat/*": false,
      "fix/*": false,
      "chore/*": false,
      "docs/*": false,
      "refactor/*": false,
      "perf/*": false,
      "test/*": false,
      "style/*": false,
      "cursor/*": false,
      "dependabot/**": false
    }
  },
  "functions": {
    "src/app/api/engine/chats/stream/route.ts": {
      "supportsCancellation": true
    },
    "src/app/api/engine/chats/*/stream/route.ts": {
      "supportsCancellation": true
    },
    "src/app/api/template/route.ts": {
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/shadcn/registry/refresh",
      "schedule": "0 */2 * * *"
    }
  ]
}
