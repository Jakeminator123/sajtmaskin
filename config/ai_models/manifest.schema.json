{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sajtmaskin.local/config/ai_models/manifest.schema.json",
  "title": "Sajtmaskin AI models manifest",
  "type": "object",
  "required": ["schemaVersion", "buildProfiles", "promptAssist", "briefing", "phaseRouting", "repairPolicies", "qualityGateTiers", "promptOrchestration", "postGenerationPasses", "preGenerationContracts", "tokenBudgets", "routeTimeouts", "workloads"],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "documentationDirectApiNote": {
      "type": "string",
      "description": "Explains that vendor docs marked direct_provider_api target direct provider APIs."
    },
    "docLinks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["vendor", "title", "url"],
        "properties": {
          "vendor": { "type": "string" },
          "title": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "appliesTo": {
            "type": "string",
            "enum": ["direct_provider_api", "sdk_or_tooling"]
          }
        }
      }
    },
    "buildProfiles": {
      "type": "object",
      "required": ["defaults", "envKeys"],
      "properties": {
        "defaults": {
          "type": "object",
          "required": ["fast", "pro", "max", "codex", "anthropic"],
          "additionalProperties": { "type": "string" }
        },
        "envKeys": {
          "type": "object",
          "required": ["fast", "pro", "max", "codex", "anthropic"],
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "qualityToOwnEngineModel": {
      "type": "object",
      "required": ["light", "standard", "pro", "premium", "max"],
      "additionalProperties": false,
      "properties": {
        "light": { "type": "string" },
        "standard": { "type": "string" },
        "pro": { "type": "string" },
        "premium": { "type": "string" },
        "max": { "type": "string" }
      }
    },
    "promptAssist": {
      "type": "object",
      "required": ["defaults", "envKeys", "allowed"],
      "additionalProperties": false,
      "properties": {
        "defaults": {
          "type": "object",
          "required": ["assist", "polish"],
          "additionalProperties": false,
          "properties": {
            "assist": { "type": "string" },
            "polish": { "type": "string" }
          }
        },
        "envKeys": {
          "type": "object",
          "required": ["assist", "polish"],
          "additionalProperties": false,
          "properties": {
            "assist": { "type": "string" },
            "polish": { "type": "string" }
          }
        },
        "allowed": {
          "type": "object",
          "required": ["gatewayClassModels", "anthropicDirectModels"],
          "additionalProperties": false,
          "properties": {
            "gatewayClassModels": { "type": "array", "items": { "type": "string" } },
            "anthropicDirectModels": { "type": "array", "items": { "type": "string" } },
            "models": { "type": "array", "items": { "type": "string" } }
          }
        },
        "notes": { "type": "string" }
      }
    },
    "briefing": {
      "type": "object",
      "required": ["defaults", "envKeys"],
      "properties": {
        "defaults": {
          "type": "object",
          "required": ["requestModel", "serverAutoOpenAI", "serverAutoAnthropic"],
          "properties": {
            "requestModel": { "type": "string" },
            "serverAutoOpenAI": { "type": "string" },
            "serverAutoAnthropic": { "type": "string" }
          }
        },
        "envKeys": {
          "type": "object",
          "required": ["requestModel", "serverAutoOpenAI", "serverAutoAnthropic"],
          "properties": {
            "requestModel": { "type": "string" },
            "serverAutoOpenAI": { "type": "string" },
            "serverAutoAnthropic": { "type": "string" }
          }
        },
        "notes": { "type": "string" }
      }
    },
    "phaseRouting": {
      "type": "object",
      "required": ["defaultByTier"],
      "properties": {
        "defaultByTier": {
          "type": "object",
          "required": ["fast", "pro", "max", "codex", "anthropic"],
          "properties": {
            "fast": { "$ref": "#/$defs/phaseRoutingTier" },
            "pro": { "$ref": "#/$defs/phaseRoutingTier" },
            "max": { "$ref": "#/$defs/phaseRoutingTier" },
            "codex": { "$ref": "#/$defs/phaseRoutingTier" },
            "anthropic": { "$ref": "#/$defs/phaseRoutingTier" }
          }
        },
        "notes": { "type": "string" }
      }
    },
    "repairPolicies": {
      "type": "object",
      "required": ["deterministicAutofixPasses", "syntaxFixPasses", "manualRepairRouteLlmPasses", "serverRepairPasses", "repairAcceptTimeoutMinutes", "partialFileRepairMaxAttempts"],
      "properties": {
        "deterministicAutofixPasses": { "type": "integer", "minimum": 1, "maximum": 10 },
        "syntaxFixPasses": { "type": "integer", "minimum": 1, "maximum": 10 },
        "manualRepairRouteLlmPasses": { "type": "integer", "minimum": 1, "maximum": 10 },
        "serverRepairPasses": { "type": "integer", "minimum": 1, "maximum": 10 },
        "repairAcceptTimeoutMinutes": { "type": "integer", "minimum": 1, "maximum": 120 },
        "partialFileRepairMaxAttempts": { "type": "integer", "minimum": 1, "maximum": 3 }
      }
    },
    "qualityGateTiers": {
      "type": "object",
      "required": ["designPreview", "integrationsBuild"],
      "properties": {
        "designPreview": { "$ref": "#/$defs/qualityGateCheckArray" },
        "integrationsBuild": { "$ref": "#/$defs/qualityGateCheckArray" }
      }
    },
    "perTierTimeouts": {
      "type": "object",
      "description": "VALIDATE-ONLY per-tier timeout overrides. Declared-only: validated but not wired to runtime (global routeTimeouts apply). See config/control-plane/policy-registry.json.",
      "required": ["fast", "pro", "max", "codex", "anthropic"],
      "properties": {
        "fast": { "$ref": "#/$defs/perTierTimeout" },
        "pro": { "$ref": "#/$defs/perTierTimeout" },
        "max": { "$ref": "#/$defs/perTierTimeout" },
        "codex": { "$ref": "#/$defs/perTierTimeout" },
        "anthropic": { "$ref": "#/$defs/perTierTimeout" }
      }
    },
    "perTierRepairPolicies": {
      "type": "object",
      "description": "VALIDATE-ONLY per-tier repair-pass overrides. Declared-only: validated but not wired to runtime (global repairPolicies apply).",
      "required": ["fast", "pro", "max", "codex", "anthropic"],
      "properties": {
        "fast": { "$ref": "#/$defs/perTierRepairPolicy" },
        "pro": { "$ref": "#/$defs/perTierRepairPolicy" },
        "max": { "$ref": "#/$defs/perTierRepairPolicy" },
        "codex": { "$ref": "#/$defs/perTierRepairPolicy" },
        "anthropic": { "$ref": "#/$defs/perTierRepairPolicy" }
      }
    },
    "perTierBriefing": {
      "type": "object",
      "description": "VALIDATE-ONLY per-tier briefing-model overrides. Declared-only: validated but not wired to runtime (global briefing defaults apply).",
      "required": ["fast", "pro", "max", "codex", "anthropic"],
      "properties": {
        "fast": { "$ref": "#/$defs/perTierBriefingEntry" },
        "pro": { "$ref": "#/$defs/perTierBriefingEntry" },
        "max": { "$ref": "#/$defs/perTierBriefingEntry" },
        "codex": { "$ref": "#/$defs/perTierBriefingEntry" },
        "anthropic": { "$ref": "#/$defs/perTierBriefingEntry" }
      }
    },
    "promptOrchestration": {
      "type": "object",
      "required": ["hardCaps", "softTargets", "phaseThresholds"],
      "properties": {
        "hardCaps": {
          "type": "object",
          "required": [
            "maxChatMessageChars",
            "warnChatMessageChars",
            "maxChatSystemChars",
            "warnChatSystemChars",
            "maxPromptHandoffChars",
            "maxAiBriefPromptChars",
            "maxAiChatMessageChars"
          ],
          "additionalProperties": false,
          "properties": {
            "maxChatMessageChars": { "$ref": "#/$defs/numericEnvSetting" },
            "warnChatMessageChars": { "$ref": "#/$defs/numericEnvSetting" },
            "maxChatSystemChars": { "$ref": "#/$defs/numericEnvSetting" },
            "warnChatSystemChars": { "$ref": "#/$defs/numericEnvSetting" },
            "maxPromptHandoffChars": { "$ref": "#/$defs/numericEnvSetting" },
            "maxAiBriefPromptChars": { "$ref": "#/$defs/numericEnvSetting" },
            "maxAiChatMessageChars": { "$ref": "#/$defs/numericEnvSetting" }
          }
        },
        "softTargets": {
          "type": "object",
          "required": [
            "freeformChars",
            "wizardChars",
            "auditChars",
            "templateChars",
            "followupChars",
            "technicalChars",
            "appChars"
          ],
          "additionalProperties": false,
          "properties": {
            "freeformChars": { "$ref": "#/$defs/numericEnvSetting" },
            "wizardChars": { "$ref": "#/$defs/numericEnvSetting" },
            "auditChars": { "$ref": "#/$defs/numericEnvSetting" },
            "templateChars": { "$ref": "#/$defs/numericEnvSetting" },
            "followupChars": { "$ref": "#/$defs/numericEnvSetting" },
            "technicalChars": { "$ref": "#/$defs/numericEnvSetting" },
            "appChars": { "$ref": "#/$defs/numericEnvSetting" }
          }
        },
        "phaseThresholds": {
          "type": "object",
          "required": ["defaultChars", "auditChars"],
          "additionalProperties": false,
          "properties": {
            "defaultChars": { "$ref": "#/$defs/numericEnvSetting" },
            "auditChars": { "$ref": "#/$defs/numericEnvSetting" }
          }
        }
      }
    },
    "postGenerationPasses": {
      "type": "object",
      "required": [
        "verifierMaxOutputTokens",
        "verifierTimeoutMs",
        "verifierSnippetCharsPerFile"
      ],
      "additionalProperties": false,
      "properties": {
        "verifierMaxOutputTokens": { "$ref": "#/$defs/numericEnvSetting" },
        "verifierTimeoutMs": { "$ref": "#/$defs/numericEnvSetting" },
        "verifierSnippetCharsPerFile": { "$ref": "#/$defs/numericEnvSetting" }
      }
    },
    "preGenerationContracts": {
      "type": "object",
      "required": ["defaults", "providerRules"],
      "properties": {
        "defaults": {
          "type": "object",
          "required": [
            "fallbackDatabaseProvider",
            "fallbackAuthProvider",
            "fallbackPaymentProvider"
          ],
          "properties": {
            "fallbackDatabaseProvider": { "type": "string" },
            "fallbackAuthProvider": { "type": "string" },
            "fallbackPaymentProvider": { "type": "string" }
          }
        },
        "providerRules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "kind",
              "provider",
              "name",
              "envVars",
              "matchPatterns",
              "reason"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["database", "auth", "payment", "integration"]
              },
              "provider": { "type": "string" },
              "name": { "type": "string" },
              "envVars": { "type": "array", "items": { "type": "string" } },
              "matchPatterns": { "type": "array", "items": { "type": "string" } },
              "status": { "type": "string", "enum": ["chosen", "optional"] },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "tokenBudgets": {
      "type": "object",
      "required": ["engineMaxOutputTokens", "autofixMaxOutputTokens", "assistMaxOutputTokens"],
      "additionalProperties": false,
      "properties": {
        "engineMaxOutputTokens": { "$ref": "#/$defs/numericEnvSetting" },
        "autofixMaxOutputTokens": { "$ref": "#/$defs/numericEnvSetting" },
        "assistMaxOutputTokens": { "$ref": "#/$defs/numericEnvSetting" }
      }
    },
    "routeTimeouts": {
      "type": "object",
      "required": [
        "engineRouteMaxDurationSeconds",
        "assistRouteMaxDurationSeconds",
        "streamSafetyTimeoutMs"
      ],
      "additionalProperties": false,
      "properties": {
        "engineRouteMaxDurationSeconds": { "$ref": "#/$defs/numericEnvSetting" },
        "assistRouteMaxDurationSeconds": { "$ref": "#/$defs/numericEnvSetting" },
        "streamSafetyTimeoutMs": { "$ref": "#/$defs/numericEnvSetting" }
      }
    },
    "embeddingModels": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/embeddingEntry" }
    },
    "generatedSiteIntegrationPlaceholders": {
      "type": "object",
      "description": "Plain-text env fragments for generated user-site preview builds (not Sajtmaskin app env). Split into a harmless layer (safe in F3) and a tier-3 stub layer (F2-only, dropped in F3).",
      "required": ["harmlessEnvFragmentFile", "tier3StubEnvFragmentFile"],
      "properties": {
        "harmlessEnvFragmentFile": {
          "type": "string",
          "description": "Filename under config/ai_models/ for placeholder values that are safe to keep in F3."
        },
        "tier3StubEnvFragmentFile": {
          "type": "string",
          "description": "Filename under config/ai_models/ for placeholder values stripped from F3 merges."
        },
        "policyDocRelativeToConfig": { "type": "string" },
        "preGenerationContractsEntry": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "workloads": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "invocation", "provider", "codeEntry", "authEnv"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "invocation": { "type": "string" },
          "provider": { "type": "string" },
          "codeEntry": { "type": "array", "items": { "type": "string" } },
          "authEnv": { "type": "array", "items": { "type": "string" } },
          "defaultModel": { "type": "string" },
          "fallbackModels": { "type": "array", "items": { "type": "string" } },
          "envOverrides": { "type": "object", "additionalProperties": { "type": "string" } },
          "tokenBudget": {
            "type": "object",
            "required": ["envKey", "default", "min", "max"],
            "properties": {
              "envKey": { "type": "string" },
              "default": { "type": "number" },
              "min": { "type": "number" },
              "max": { "type": "number" }
            }
          },
          "notes": { "type": "string" },
          "anthropicModelIdNormalization": { "type": "string" },
          "docLinks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["vendor", "title", "url"],
              "properties": {
                "vendor": { "type": "string" },
                "title": { "type": "string" },
                "url": { "type": "string", "format": "uri" },
                "appliesTo": {
                  "type": "string",
                  "enum": ["direct_provider_api", "sdk_or_tooling"]
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "numericEnvSetting": {
      "type": "object",
      "required": ["envKey", "default", "min", "max"],
      "properties": {
        "envKey": { "type": "string" },
        "default": { "type": "number" },
        "min": { "type": "number" },
        "max": { "type": "number" }
      }
    },
    "phaseRoutingTier": {
      "type": "object",
      "required": ["planner", "generator", "fixer", "verifier", "deploy-assistant"],
      "properties": {
        "planner": { "type": "string" },
        "generator": { "type": "string" },
        "fixer": { "type": "string" },
        "verifier": { "type": "string" },
        "deploy-assistant": { "type": "string" }
      }
    },
    "qualityGateCheckArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["typecheck", "build", "lint"]
      }
    },
    "perTierTimeout": {
      "type": "object",
      "required": ["engineRouteMaxDurationSeconds", "verifierTimeoutMs"],
      "properties": {
        "engineRouteMaxDurationSeconds": { "type": "number" },
        "verifierTimeoutMs": { "type": "number" }
      }
    },
    "perTierRepairPolicy": {
      "type": "object",
      "required": ["deterministicAutofixPasses", "syntaxFixPasses", "serverRepairPasses"],
      "properties": {
        "deterministicAutofixPasses": { "type": "number" },
        "syntaxFixPasses": { "type": "number" },
        "serverRepairPasses": { "type": "number" }
      }
    },
    "perTierBriefingEntry": {
      "type": "object",
      "required": ["briefingModel"],
      "properties": {
        "briefingModel": { "type": "string" }
      }
    },
    "embeddingEntry": {
      "type": "object",
      "required": ["model"],
      "additionalProperties": false,
      "properties": {
        "model": { "type": "string" },
        "dimensions": { "type": "number" },
        "codeEntry": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
