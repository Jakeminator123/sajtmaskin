    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.58.2",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.22.4",
    "vitest": "^4.1.9"
  },
