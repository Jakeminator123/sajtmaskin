    },
    {
      "key": "SAJTMASKIN_DEFER_EXTRA_ROUTES_ON_INIT",
      "classification": "optional_runtime",
      "recommendedVercelTargets": [
        "development",
        "preview",
        "production"
      ],
      "notes": "When true/1, init generations may still plan multiple routes but should fully realize only the primary route while extra planned routes start as lightweight shells. Default off."
    },
    {
      "key": "SAJTMASKIN_F2_PRODUCT_POSTCHECK",
      "classification": "optional_runtime",
      "recommendedVercelTargets": [
        "development",
        "preview"
      ],
      "notes": "Opt-in. Enables server-side F2 Product Postcheck via Playwright for trusted preview URLs only (localhost / configured preview-host / vm-fly-jakem.fly.dev). Produces product_postcheck.* warnings in existing version diagnostics; does not block F2 rendering. Blocking product findings can keep the F3 trigger disabled until the visible preview works."
    },
    {
      "key": "SAJTMASKIN_REFUSE_DOSSIER_STUBS",
      "classification": "optional_runtime",
      "recommendedVercelTargets": [
        "development",
        "preview",
        "production"
      ],
      "notes": "Opt-in (grandmaster A7-2 false-green hardening). When true/1, autofix refuses to fabricate a silent null-render stub for a dossier-exposed import the LLM did not emit; the unresolved import then degrades/blocks the preview honestly (preview blocked with reason via runProjectSanityChecks code_structure_failure) instead of shipping a hollow false-green page. Default off. Reversible: set false/unset to restore the silent-stub behavior. Recommended rollout: enable on preview first and watch how often legitimate builds get blocked (frequency is LLM-runtime dependent) before production. Source: src/lib/gen/autofix/rules/cross-file-import-checker.ts (FEATURES.refuseDossierStubs)."
    },
    {
      "key": "SAJTMASKIN_PREVIEW_PREWARM",
      "classification": "optional_runtime",
      "recommendedVercelTargets": [
        "development",
        "preview"
      ],
      "notes": "Opt-in preview latency; DEFAULT OFF and unset until preview-host deploys first. Requires SAJTMASKIN_PREVIEW_HOST_BASE_URL + SAJTMASKIN_PREVIEW_HOST_API_KEY; missing API key skips optional prewarm while normal preview remains unchanged. A NEW chat's real codegen may overlap baseline install; plan, clarification and ordinary follow-ups never prewarm. Ownership blocks delayed downgrade; HTTP hides skeleton, all WS upgrades are refused, and failed real replacement is stable 503 until explicit retry. Before credit settlement, one persistent active-subject lease uses verified userId or canonical trusted-IP guest identity from rateLimit.ts, sent as API-keyed HMAC. Boot failure retains cooldown; real claim/update/patch/destroy/cleanup/expiry/reset releases. Fixed code cap 4096; no PREVIEW_HOST_MAX_PREWARM_LEASES env. Deploy host check+guards+proxy+smoke/Fly health before app; no activation in this change."
    },
    {
      "key": "SAJTMASKIN_STRICT_GENERATED_ARTIFACTS",
      "classification": "optional_runtime",
      "recommendedVercelTargets": [
        "development",
        "preview",
        "production"
      ],
      "notes": "Fail fast when required generated scaffold artifacts (scaffold-research.generated.json / scaffold-embeddings.json) are missing or empty. Default is strict outside tests."
    },
    {
      "key": "SAJTMASKIN_PRE_VM_TYPECHECK",
      "classification": "optional_runtime",
      "recommendedVercelTargets": [
        "development",
        "preview",
        "production"
      ],
      "notes": "Feature flag for pre-VM `tsc --noEmit` against the warm scaffold node_modules cache (`src/lib/gen/preview/warm-typecheck.ts`). Off by default. F3 generations force-run regardless. When the cache is cold the phase fails open so the pipeline never blocks."
    },
    {
      "key": "SAJTMASKIN_PRE_VM_TYPECHECK_CACHE_ROOT",
      "classification": "optional_runtime",
      "recommendedVercelTargets": [
        "development",
        "preview",
        "production"
      ],
      "notes": "Override directory for the per-scaffold typecheck cache (defaults to `<tmpdir>/sajtmaskin/typecheck-cache`). One subdirectory per scaffold id, each with its own `node_modules` + `tsconfig.json`."
    },
    {
      "key": "SAJTMASKIN_BLOCKING_ESLINT",
      "classification": "optional_runtime",
      "recommendedVercelTargets": [
        "development",
        "preview",
        "production"
      ],
      "notes": "Explicit opt-in for local warm-cache ESLint diagnostics (`src/lib/gen/preview/warm-eslint.ts`). Non-authoritative: finalize does not call it, it never starts RepairGate, and it never affects promotion. F3 lint is owned exclusively by the project-local VM ReleaseGate."
    },
    {
      "key": "SAJTMASKIN_BLOCKING_ESLINT_MAX_WARNINGS",
      "classification": "optional_runtime",
      "recommendedVercelTargets": [
        "development",
        "preview",
        "production"
      ],
      "notes": "Warning threshold for optional local warm-eslint diagnostics only. It does not change VM ReleaseGate severity: VM lint errors block, warnings are always Advisory."
    },
    {
      "key": "SAJTMASKIN_SHIM_PREVIEW_DISABLED",
      "classification": "optional_runtime",
      "recommendedVercelTargets": [
        "preview",
        "production"
      ],
      "notes": "Legacy shim-preview opt-out/opt-in switch. Default runtime behavior is disabled; set to 0/false/off/no only for temporary compatibility debugging."
    },
    {
      "key": "SAJTMASKIN_AUTO_REPAIR_BUILD_ERROR",
      "classification": "optional_runtime",
      "recommendedVercelTargets": [
        "development",
        "preview",
        "production"
      ],
      "notes": "Controls the post-VM `triggerBuildErrorRepair` loop in `src/lib/gen/verify/server-verify.ts`. Default ON in `development` and Vercel `preview`, default OFF in `production`. Explicit `1`/`true`/`on`/`yes` or `0`/`false`/`off`/`no` overrides the per-environment default. Same `inflight` dedup as server-verify so the same versionId never repairs twice in parallel."
    },
    {
      "key": "SAJTMASKIN_METRICS_TOKEN",
      "classification": "optional_runtime",
      "recommendedVercelTargets": [
        "development",
        "preview",
        "production"
      ],
      "notes": "Bearer token required to access /api/metrics. Empty/unset = route returns 503 (disabled)."
    },
    {
      "key": "VERCEL_TOKEN",
      "classification": "shared_runtime",
      "recommendedVercelTargets": [
        "development",
        "preview",
        "production"
      ],
      "notes": "Create at https://vercel.com/account/tokens. Used for Vercel REST API across deploy/admin/domain flows in this repo."
    },
    {
      "key": "VERCEL_TOKEN_FULL",
      "classification": "local_only",
      "recommendedVercelTargets": [],
      "notes": "Deprecated — consolidated into VERCEL_TOKEN (vcp_ format). Remove from .env.local if present."
    },
    {
      "key": "VERCEL_TEAM_ID",
      "classification": "optional_runtime",
      "recommendedVercelTargets": [
        "development",
        "preview",
        "production"
      ],
      "notes": "Team / org scope (often team_…). Used together with VERCEL_TOKEN + VERCEL_PROJECT_ID for Vercel REST API calls that need explicit team/project scoping. Find via linked project: run vercel link in the repo and read .vercel/project.json → orgId, or Team Settings → Team ID in the dashboard."
    },
    {
      "key": "VERCEL_PROJECT_ID",
      "classification": "shared_runtime",
      "recommendedVercelTargets": [
        "development",
