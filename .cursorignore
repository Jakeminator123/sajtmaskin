# =============================================================================
# SAJTMASKIN .cursorignore
# =============================================================================
# Files here are NOT indexed by Cursor.
# Agents can still read ignored files via explicit path when needed.
# This reduces indexing noise and keeps Cursor fast.
# =============================================================================
#
# README policy (indexing)
# ------------------------
# Where a directory is ignored below, we often re-include `README.md` with a
# leading `!` so agents still see a short "what lives here" entry.
# Exception: do NOT re-include READMEs under path segments named `old`,
# `archive`, or `archived` (e.g. docs/old, docs/plans/archived,
# .cursor/migration-archive, .cursor/automation/archive,
# .cursor/orchestrator/archive). Those trees stay fully ignored for indexing;
# open files by explicit path if needed.
# =============================================================================

# Build/cache
node_modules
.next
.cache
dist
build
coverage

# Git metadata / generated lockfiles
.git
tsconfig.tsbuildinfo
package-lock.json

# Local env / secrets / local status
.env
.env.*
.env.local
.env.production
.token-status.json

# Local browser / automation config
#config.browser.txt
config.txt
config.example.txt
sajtmaskin.code-workspace

# Large media
public/video/
public/images/
*.mp4
*.webm

.j_to_agent/structure_bugs_and_parralells
.j_to_agent/analysis

# ---------------------------------------------------------------------------
# Stable code that rarely changes (read via explicit path when needed)
# ---------------------------------------------------------------------------

# shadcn/ui primitives — generated, not hand-edited
src/components/ui/

# Static assets
public/

# Dev runner scripts (Next, DB, Vercel template sync) — keep README + entrypoints.
#Scripts/**
!Scripts/README.md
!Scripts/*.mjs
!Scripts/*.ts

# Offline pipeline / embeddings / research helpers (see config/README.md)
#config/scripts/**
!config/scripts/README.md
!config/scripts/*.ts

# Admin dashboard routes
src/app/api/admin/

# Payment routes (sensitive, rarely changed)
src/app/api/stripe/

# Auth routes (stable, rarely changed)
src/app/api/auth/

# Landing page components (stable after design)
src/components/landing-v2/

# Legacy research paths (kept for backward compat)
research/
!research/README.md
_template_refs/
_sidor/
vercel_usecase_next_react_templates/

# Generated reports and machine-generated artifacts
src/lib/gen/data/docs-embeddings.json
src/lib/gen/data/docs-snippets.ts
# src/lib/gen/preview/shims.ts — unignored for preview debugging
src/lib/gen/scaffolds/scaffold-embeddings.json
src/lib/gen/scaffolds/scaffold-research.generated.json
src/lib/gen/template-library/template-library-embeddings.json
src/lib/gen/template-library/template-library.generated.json

# Recovery package
world-class-recovery/

# MCP scraped docs (prefer MCP search/fetch instead)
services/mpc/docs/docgrab__*/
services/mpc/docs/local/
services/mpc/docs/*llms*
services/mpc/docs/shad/
services/mpc/logs/

# ---------------------------------------------------------------------------
# Session state and legacy
# ---------------------------------------------------------------------------

# Local Cursor session state
#.cursor/plans/
#.cursor/documents/
.cursor/automation/runs/
.cursor/automation/archive/
.cursor/automation/input/

# Archived or low-signal docs (no README re-include; see README policy header)
docs/old/**
docs/plans/archived/**
#docs/analyses/

# Migration archive (moved from STOR_MIGRATION/ to .cursor/migration-archive/)
.cursor/migration-archive/**

# Temporary / local dev folders
old/
skrapning/
ovrigt/
.preprompt_history.json

logs/
manual_log/
input_files_for_cursor/
DOM_dev_tols.txt
chat_till_vanster.txt

# Misc legacy folders
#.j_to_agent/

# Orchestrator run folders
.cursor/orchestrator/run/*/
.cursor/orchestrator/archive/

tests/openclaw/**
!tests/openclaw/README.md

internt_jakob/
#.vercel/

