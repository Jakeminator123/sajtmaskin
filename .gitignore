# =============================================================================
# SAJTMASKIN .gitignore
# =============================================================================

# Python bytecode
__pycache__/
*.pyc

# Node/Next.js
node_modules/
.next/
out/
.cache/
dist/
build/
coverage/

# Generated files (recreated on build)
tsconfig.tsbuildinfo
next-env.d.ts

# Environment files (NEVER commit secrets!)
.env
.env.*
.env.local
*.pem
*key
.env.production
.token-status.json

# Database files (local data, not for git)
data/*.db
data/*.db-shm
data/*.db-wal
data/uploads/

# MCP scraped documentation (60+ MB, regenerate with doc.py)
services/mpc/docs/docgrab__*/
services/mpc/docs/local/
services/mpc/docs/*llms*
services/mpc/docs/SDK_6.md
services/mpc/docs/shad/
services/mpc/logs/

# Editor/OS
.idea/
.DS_Store
Thumbs.db
# Cursor-specific (plans are session-specific, mcp.json is shared)
.cursor/plans/
.cursor/documents/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
mcp-monitoring-report.txt
logs/
manual_log/
input_files_for_cursor/logg_*.txt
DOM_dev_tols.txt
chat_till_vanster.txt

# Temp/dev files
.preprompt_history.json
övrigt
skrapning
/[{]*.png
_env.production
_env.development

# Avoid accidentally committing a nested clone/repo
sajtgen

# Large local docs/specs (keep out of git unless intentionally added)
SiteStudio_Projektspecifikation_ifillningsbar_v2.pdf
ANALYS-*.txt

# Local env dumps (often contain secrets)
environments.production
vercel-env-deploy.txt
git_env.txt

old/
senaste_miljovariablar/
sajtmaskin.code-workspace

# Automation kit (local-only)
automation/
.automation/
.cursor-gpt-kit/
config.txt
config.browser.txt
config.example.txt
INSTALERA.py
INSTALLERA.py
check_env.py

# Vercel
.vercel

# >>> cursor-gpt automation local artifacts >>>
.cursor/agents/
.cursor/rules/automation-safety.mdc
automation/
config.txt
config.example.txt
config.browser.txt
INSTALLERA.py
INSTALERA.py
.cursor-gpt-kit/
.automation/
automation/state/run-state.json
automation/state/ui-dashboard/
automation/inbox/deep-research-report*.md
automation/inbox/tmp-*
automation/runtime/browser-input-*.md
automation/packets/iteration-*/
automation/reports/iteration-*/
automation/reports/browser-run-iteration-*.json
automation/reports/final-summary.md
automation/reports/final-summary.json
playwright-report/
test-results/
node_modules/
