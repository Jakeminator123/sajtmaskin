# Sajtmaskin — env template
# Copy to .env.local and fill in values. See docs/ENV.md for details.

# Database (Neon Postgres via Vercel Marketplace)
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Redis / KV (Upstash via Vercel Marketplace)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN=

# Auth
JWT_SECRET=

# AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Vercel platform
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# Image APIs
UNSPLASH_ACCESS_KEY=

# Preview host (tier-2)
SAJTMASKIN_PREVIEW_HOST_BASE_URL=
SAJTMASKIN_PREVIEW_HOST_API_KEY=

# Cron secret (required in prod; without it, cron routes reject all requests)
CRON_SECRET=

# Feature flags (optional, see config/env-policy.json)
# SAJTMASKIN_RUNTIME_TEMPLATE_GUIDANCE=true
# SAJTMASKIN_USE_VARIANT_STRUCTURAL_FILES=true
