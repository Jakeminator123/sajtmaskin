{
  "$schema": "../../../docs/schemas/strict/dossier.schema.json",
  "id": "auth-chatbot",
  "kind": "integration",
  "category": "auth",
  "label": "Chatbot",
  "description": "A full-featured, hackable Next.js AI chatbot built by Vercel",
  "summary": "Use this dossier when the site needs authenticated chat or account-aware AI features backed by NextAuth. It provides the core auth/session wrapper, Postgres/Drizzle configuration, structured API error handling, and Redis-based per-IP rate limiting patterns used by the Vercel AI chatbot.",
  "providers": [
    {
      "name": "Vercel",
      "url": "https://github.com/vercel/chatbot"
    }
  ],
  "envVars": [
    {
      "key": "AUTH_SECRET",
      "required": true,
      "purpose": "generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`"
    },
    {
      "key": "AI_GATEWAY_API_KEY",
      "required": true,
      "purpose": "https://vercel.com/ai-gateway"
    },
    {
      "key": "BLOB_READ_WRITE_TOKEN",
      "required": true,
      "purpose": "https://vercel.com/docs/vercel-blob"
    },
    {
      "key": "POSTGRES_URL",
      "required": true,
      "purpose": "https://vercel.com/docs/postgres"
    },
    {
      "key": "REDIS_URL",
      "required": true,
      "purpose": "https://vercel.com/docs/redis"
    }
  ],
  "dependencies": [
