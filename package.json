{
  "name": "sajtmaskin-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.14.0 <23"
  },
  "volta": {
    "node": "22.14.0"
  },
  "scripts": {
    "predev": "node scripts/dev/check-systemprompt.mjs && node scripts/dev/refresh-token.mjs && node scripts/db/db-init.mjs",
    "dev": "node scripts/dev/next-runner.mjs dev",
    "refresh-token": "node scripts/dev/refresh-token.mjs",
    "prebuild": "node scripts/dev/check-systemprompt.mjs",
    "build": "node scripts/dev/next-runner.mjs build",
    "start": "node scripts/dev/next-runner.mjs start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:watch": "npx nodemon --ext ts,tsx,js,jsx --exec \"eslint . --fix\"",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "devtest": "npm run typecheck && npm run scaffolds:validate && npm run test:ci && npm run lint",
    "db:init": "node scripts/db/db-init.mjs",
    "db:check": "node scripts/db/check-dev-db.mjs",
    "db:rows": "node scripts/db/db-row-overview.mjs",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:focused": "vitest run src/components/builder/BuilderMessageTooling.test.tsx src/lib/hooks/chat/helpers.test.ts src/lib/hooks/chat/post-checks.test.ts src/lib/hooks/chat/stream-handlers.test.ts src/lib/gen/stream/finalize-version.test.ts src/lib/gen/post-process/image-materializer.test.ts src/lib/gen/preview-quality-gate.test.ts src/lib/gen/server-verify.test.ts src/lib/providers/own-engine/generation-stream-post-finalize.test.ts src/lib/gen/eval/runner.test.ts src/lib/gen/eval/baseline.test.ts src/lib/gen/eval/scorecard.test.ts src/app/api/engine/chats/[chatId]/quality-gate/route.test.ts",
    "test:openclaw:e2e": "playwright test -c playwright.openclaw.config.ts",
    "test:deploy-smoke:e2e": "playwright test -c playwright.deploy-smoke.config.ts",
    "templates:sync": "node scripts/v0-templates/sync-v0-templates.mjs",
    "templates:validate": "node scripts/v0-templates/validate-templates.mjs",
    "templates:refresh": "node scripts/v0-templates/sync-v0-templates.mjs && node scripts/v0-templates/validate-templates.mjs",
    "templates:local:refresh": "node scripts/v0-templates/refresh-local-v0-catalog.mjs",
    "templates:local:refresh:embeddings": "node scripts/v0-templates/refresh-local-v0-catalog.mjs --with-embeddings",
    "templates:embeddings": "npx tsx scripts/embeddings/generate-template-embeddings.ts",
    "template-library:import": "npx tsx scripts/template-library/import-template-discovery.ts",
    "template-library:hydrate-cache": "npx tsx scripts/template-library/hydrate-template-library-cache.ts",
    "template-library:build": "npx tsx scripts/template-library/build-template-library.ts",
    "template-library:validate-runtime": "npx tsx scripts/template-library/validate-runtime-artifacts.ts",
    "template-library:verify-summary": "npx tsx scripts/template-library/verify-discovered-summary.ts",
    "template-library:embeddings": "npx tsx scripts/embeddings/generate-template-library-embeddings.ts",
    "template-pipeline:refresh": "python scripts/template-library/full_template_refresh.py",
    "template-pipeline:refresh:reuse-cache": "python scripts/template-library/full_template_refresh.py --skip-scrape",
    "runtime-library:audit": "npx tsx scripts/audit/audit-runtime-library.ts",
    "artifacts:rebuild": "python scripts/rebuild_artifacts.py --with-typecheck",
    "artifacts:rebuild:full": "python scripts/rebuild_artifacts.py --refresh-scrape --with-typecheck",
    "artifacts:rebuild:with-eval": "python scripts/rebuild_artifacts.py --with-eval --with-typecheck",
    "artifacts:rebuild:full:with-eval": "python scripts/rebuild_artifacts.py --refresh-scrape --with-eval --with-typecheck",
    "scripts:dashboard": "python scripts/scripts_dashboard.py",
    "inspector:start": "node services/inspector-worker/server.mjs",
    "inspector:install": "cd services/inspector-worker && npm install && npx playwright install chromium",
    "inspector:health": "curl -sf http://localhost:3310/health || echo UNHEALTHY",
    "inspector:docker:up": "docker compose -f infra/inspector-worker/docker-compose.yml up -d --build",
    "inspector:docker:down": "docker compose -f infra/inspector-worker/docker-compose.yml down",
    "inspector:docker:logs": "docker compose -f infra/inspector-worker/docker-compose.yml logs -f inspector-worker",
    "inspector:docker:ps": "docker compose -f infra/inspector-worker/docker-compose.yml ps",
    "references:discover": "npx playwright test e2e/vercel-templates/scrape-catalog.spec.ts -g \"automated: scrape with sajtmaskin preset filters\"",
    "references:discover:second-pass": "npx playwright test e2e/vercel-templates/scrape-catalog.spec.ts -g \"automated: scrape with secondPass preset filters\"",
    "references:discover:full": "npx playwright test e2e/vercel-templates/scrape-catalog.spec.ts -g \"automated: scrape with broad preset filters\"",
    "scaffolds:status": "python scripts/scaffolds/scaffold_cli.py status",
    "scaffolds:import": "python scripts/scaffolds/scaffold_cli.py import",
    "scaffolds:hydrate": "python scripts/scaffolds/scaffold_cli.py hydrate",
    "scaffolds:build": "python scripts/scaffolds/scaffold_cli.py build",
    "scaffolds:embeddings": "python scripts/scaffolds/scaffold_cli.py embeddings",
    "scaffolds:eval": "python scripts/scaffolds/scaffold_cli.py eval",
    "scaffolds:verify": "python scripts/scaffolds/scaffold_cli.py verify",
    "scaffolds:all": "python scripts/scaffolds/scaffold_cli.py all",
    "scaffolds:curate": "npx tsx scripts/scaffolds/curate-scaffold-candidates.ts",
    "scaffolds:promote": "npx tsx scripts/scaffolds/promote-to-scaffold.ts",
    "scaffolds:validate": "npx vitest run src/lib/gen/scaffolds/scaffold-manifest-validation.test.ts",
    "baseline-deps:verify": "npx tsx scripts/deps/validate-baseline-npm-versions.ts",
    "baseline-deps:tree": "npx tsx scripts/deps/validate-baseline-npm-tree.ts",
    "eval": "npx tsx scripts/eval/run-eval.ts",
    "eval:suite": "npx tsx src/lib/gen/eval/cli.ts",
    "eval:gate": "npx tsx src/lib/gen/eval/cli.ts --gate",
    "eval:baseline": "npx tsx src/lib/gen/eval/cli.ts --save-baseline",
    "db:migrate": "npx tsx scripts/db/run-migrations.ts",
    "db:push": "node scripts/db/db-push.mjs",
    "db:generate": "npx drizzle-kit generate",
    "mirror:audit": "node scripts/audit/audit-shadcn-mirror-repos.mjs",
    "mirror:audit:verbose": "node scripts/audit/audit-shadcn-mirror-repos.mjs --verbose",
    "mirror:audit:json": "node scripts/audit/audit-shadcn-mirror-repos.mjs --json",
    "mirror:audit:strict": "node scripts/audit/audit-shadcn-mirror-repos.mjs --strict"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.18",
    "@base-ui/react": "^1.2.0",
    "@d-id/client-sdk": "^1.1.52",
    "@hookform/resolvers": "^5.2.2",
    "@paper-design/shaders-react": "^0.0.71",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@streamdown/code": "^1.1.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.3.1",
    "@vercel/speed-insights": "^1.3.1",
    "@xyflow/react": "^12.10.0",
    "ai": "^6.0.69",
    "cheerio": "^1.0.0-rc.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.29.0",
    "input-otp": "^1.4.2",
    "ioredis": "^5.9.2",
    "jszip": "^3.10.1",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.563.0",
    "ms": "^2.1.3",
    "nanoid": "^5.1.6",
    "next": "^16.1.4",
    "next-themes": "^0.4.6",
    "openai": "^6.16.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.17.2",
    "postcss": "^8.5.1",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.7.2",
    "react-syntax-highlighter": "^16.1.0",
    "recharts": "^2.15.4",
    "resend": "^6.9.1",
    "sonner": "^2.0.7",
    "streamdown": "^2.4.0",
    "stripe": "^20.2.0",
    "swr": "^2.3.8",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "three": "^0.183.2",
    "tokenlens": "^1.3.1",
    "typescript": "5.9.3",
