  "rules": [
    {
      "key": "NODE_ENV",
      "classification": "vercel_managed",
      "recommendedVercelTargets": [],
      "notes": "Set automatically by Vercel and Node.js runtime. Do not push local value."
    },
    {
      "key": "NEXT_PHASE",
      "classification": "vercel_managed",
      "recommendedVercelTargets": [],
      "notes": "Set internally by Next.js build/runtime phases."
    },
    {
      "key": "RENDER",
      "classification": "local_only",
      "recommendedVercelTargets": [],
      "notes": "Render platform flag. Irrelevant on Vercel deployments."
    },
    {
      "key": "POSTGRES_URL",
      "classification": "shared_runtime",
      "recommendedVercelTargets": ["development", "preview", "production"],
      "notes": "Primary database connection for the app."
    },
    {
      "key": "POSTGRES_URL_NON_POOLING",
      "classification": "optional_runtime",
      "recommendedVercelTargets": ["development", "preview", "production"],
      "notes": "Direct non-pooled database URL."
    },
    {
      "key": "JWT_SECRET",
      "classification": "shared_runtime",
      "recommendedVercelTargets": ["development", "preview", "production"],
      "notes": "Required for auth and session integrity."
    },
    {
      "key": "OPENAI_API_KEY",
      "classification": "shared_runtime",
      "recommendedVercelTargets": ["development", "preview", "production"],
      "notes": "Required for the default own-engine path."
    },
    {
      "key": "AUDIT_WEB_SEARCH",
      "classification": "optional_runtime",
      "recommendedVercelTargets": ["development", "preview", "production"],
      "notes": "Optional flag for OpenAI-backed audit web search."
    },
    {
      "key": "SAJTMASKIN_BUILD_SPEC_ENABLED",
      "classification": "optional_runtime",
      "recommendedVercelTargets": ["development", "preview", "production"],
      "notes": "Feature flag for additive BuildSpec derivation and rollout in the generation pipeline."
    },
    {
      "key": "SAJTMASKIN_LIGHTWEIGHT_SCAFFOLD_SERIALIZATION",
      "classification": "optional_runtime",
      "recommendedVercelTargets": ["development", "preview", "production"],
      "notes": "Feature flag for budgeted scaffold serialization instead of broad scaffold file dumps."
    },
    {
      "key": "SAJTMASKIN_FOLLOWUP_LIGHT_CONTEXT",
      "classification": "optional_runtime",
      "recommendedVercelTargets": ["development", "preview", "production"],
      "notes": "Feature flag for lighter follow-up context and reduced reference retrieval on narrow edits."
    },
    {
      "key": "SAJTMASKIN_FINALIZE_DEEP_PATH_ENABLED",
      "classification": "optional_runtime",
      "recommendedVercelTargets": ["development", "preview", "production"],
      "notes": "Feature flag for deep-path finalize steps such as image materialization and polish on non-light flows."
    },
    {
      "key": "SAJTMASKIN_STRICT_GENERATED_ARTIFACTS",
      "classification": "optional_runtime",
      "recommendedVercelTargets": ["development", "preview", "production"],
      "notes": "Fail fast when required generated template-library or scaffold-research artifacts are missing or empty. Default is strict outside tests."
    },
    {
      "key": "VERCEL_TOKEN",
      "classification": "shared_runtime",
      "recommendedVercelTargets": ["development", "preview", "production"],
      "notes": "Create at https://vercel.com/account/tokens. Used for Vercel REST API and, with TEAM+PROJECT, passed explicitly into @vercel/sandbox Sandbox.create (SDK does not auto-read this var). Tier-2 user preview defaults to preview_host when configured; these credentials are mainly for explicit Vercel tier-2 mode/fallback."
    },
    {
      "key": "VERCEL_TOKEN_FULL",
      "classification": "local_only",
      "recommendedVercelTargets": [],
      "notes": "Deprecated — consolidated into VERCEL_TOKEN (vcp_ format). Remove from .env.local if present."
    },
    {
      "key": "VERCEL_TEAM_ID",
      "classification": "optional_runtime",
      "recommendedVercelTargets": ["development", "preview", "production"],
      "notes": "Team / org scope (often team_…). Required together with VERCEL_TOKEN + VERCEL_PROJECT_ID for @vercel/sandbox from local dev (explicit Vercel tier-2 fallback/mode). Find via linked project: run vercel link in the repo and read .vercel/project.json → orgId, or Team Settings → Team ID in the dashboard."
    },
    {
      "key": "VERCEL_PROJECT_ID",
      "classification": "shared_runtime",
      "recommendedVercelTargets": ["development", "preview", "production"],
      "notes": "Project id (prj_…). Required with VERCEL_TOKEN + VERCEL_TEAM_ID for @vercel/sandbox from local dev (explicit Vercel tier-2 fallback/mode). From Project Settings → General, or .vercel/project.json after vercel link."
    },
    {
      "key": "VERCEL_WEBHOOK_SECRET",
      "classification": "optional_runtime",
      "recommendedVercelTargets": ["development", "preview", "production"],
      "notes": "Validates inbound Vercel webhooks."
    },
    {
      "key": "VERCEL_OIDC_TOKEN",
      "classification": "environment_specific",
      "recommendedVercelTargets": ["development"],
      "notes": "Alternative to VERCEL_TOKEN+TEAM+PROJECT for @vercel/sandbox: pulled locally via vercel env pull (Vercel CLI). On Vercel-hosted runtimes the platform may inject OIDC; treat pulled .env values as local-only snapshots. Primärt relevant för explicit Vercel tier-2 mode/fallback."
    },
    {
      "key": "NEXT_PUBLIC_APP_URL",
      "classification": "environment_specific",
      "recommendedVercelTargets": ["preview", "production"],
