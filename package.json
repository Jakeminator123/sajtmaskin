{
  "name": "sajtmaskin-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "volta": {
    "node": "22.14.0"
  },
  "scripts": {
    "predev": "node scripts/refresh-token.mjs && node scripts/db-init.mjs",
    "dev": "node scripts/next-runner.mjs dev",
    "refresh-token": "node scripts/refresh-token.mjs",
    "build": "node scripts/next-runner.mjs build",
    "start": "node scripts/next-runner.mjs start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:watch": "npx nodemon --ext ts,tsx,js,jsx --exec \"eslint . --fix\"",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "devtest": "npm run typecheck && npm run scaffolds:validate && npm run test:ci && npm run lint",
    "db:init": "node scripts/db-init.mjs",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:api": "node scripts/test-api-usage.mjs",
    "templates:sync": "node scripts/sync-v0-templates.mjs",
    "templates:validate": "node scripts/validate-templates.mjs",
    "templates:refresh": "node scripts/sync-v0-templates.mjs && node scripts/validate-templates.mjs",
    "templates:embeddings": "npx tsx scripts/generate-template-embeddings.ts",
    "template-library:build": "npx tsx scripts/build-template-library.ts",
    "template-library:embeddings": "npx tsx scripts/generate-template-library-embeddings.ts",
    "runtime-library:audit": "npx tsx scripts/audit-runtime-library.ts",
    "inspector:start": "node services/inspector-worker/server.mjs",
    "inspector:install": "cd services/inspector-worker && npm install && npx playwright install chromium",
    "inspector:health": "curl -sf http://localhost:3310/health || echo UNHEALTHY",
    "inspector:docker:up": "docker compose -f infra/inspector-worker/docker-compose.yml up -d --build",
    "inspector:docker:down": "docker compose -f infra/inspector-worker/docker-compose.yml down",
    "inspector:docker:logs": "docker compose -f infra/inspector-worker/docker-compose.yml logs -f inspector-worker",
    "inspector:docker:ps": "docker compose -f infra/inspector-worker/docker-compose.yml ps",
    "references:discover": "python big_scarfold/hamta_sidor.py --skip-download --output research/external-templates/raw-discovery --per-category 8 --delay 1.0",
    "references:discover:full": "python big_scarfold/hamta_sidor.py --output research/external-templates/raw-discovery --per-category 6 --delay 1.5",
    "scaffolds:discover": "npm run references:discover",
    "scaffolds:discover:full": "npm run references:discover:full",
    "scaffolds:validate": "npx vitest run src/lib/gen/scaffolds/scaffold-manifest-validation.test.ts",
    "docs:embeddings": "npx tsx scripts/generate-docs-embeddings.ts",
    "eval": "npx tsx scripts/run-eval.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.18",
    "@base-ui/react": "^1.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@paper-design/shaders-react": "^0.0.71",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@streamdown/code": "^1.1.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/google.maps": "^3.58.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.0.1",
    "@vercel/sandbox": "^1.3.1",
    "@vercel/speed-insights": "^1.3.1",
    "@xyflow/react": "^12.10.0",
    "ai": "^6.0.69",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.0.0-rc.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
