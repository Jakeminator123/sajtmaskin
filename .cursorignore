# =============================================================================
# SAJTMASKIN .cursorignore
# =============================================================================
# Files here are NOT indexed by Cursor.
# Use direct file reads when you intentionally need one of these artifacts.
# Keep runtime-critical generated JSON hidden by default to reduce indexing
# noise; open them directly only when a task actually depends on them.
# =============================================================================

# Build/cache
node_modules
.next
.cache
dist
build
coverage

# Git metadata / generated lockfiles
.git
tsconfig.tsbuildinfo
package-lock.json

# Local env / secrets
#.env
#".env.*
#.env.local
#.env.production

# Large media
public/video/
*.mp4
*.webm

# Local research lanes and clone mirrors
research/external-templates/raw-discovery/
research/external-templates/repo-cache/
research/external-templates/reference-library/
_template_refs/
_sidor/
research/_sidor/
vercel_usecase_next_react_templates/

# Generated reports and machine-generated artifacts
data/scaffold-candidates-curated.json
next_sidan_skrapning.txt
src/lib/gen/data/docs-embeddings.json
src/lib/gen/scaffolds/scaffold-embeddings.json
src/lib/gen/scaffolds/scaffold-research.generated.json
src/lib/gen/template-library/template-library-embeddings.json
src/lib/gen/template-library/template-library.generated.json

# MCP scraped docs (prefer MCP search/fetch instead)
services/mpc/docs/docgrab__*/
services/mpc/docs/local/
services/mpc/docs/*llms*
services/mpc/docs/shad/
services/mpc/logs/

# Archived or low-signal docs
docs/old/
docs/plans/archived/

# Temporary / local dev folders
old/
#skrapning/
ovrigt/
.preprompt_history.json
.vercel/output/

# Orchestrator run folders (use exact paths; reduces indexing tokens)
.cursor/orchestrator/run/*/
.cursor/orchestrator/archive/
