{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "redis-health-check-report.schema.json",
  "title": "Redis Health Check Report",
  "description": "JSON-payload på stdout från `scripts/db/redis-health-check.mjs`. Konsumeras av `backoffice/pages/redis_health.py` (subprocess.run + json.loads). Två-grenat: (1) success med full payload; (2) fail-grenar (creds saknas eller ping-fail). VIKTIGT: testar ENDAST Upstash REST-klienten (`@upstash/redis`) — inte ioredis/TCP-vägen som app-cache använder. Source of truth: scripts/db/redis-health-check.mjs.",
  "oneOf": [
    { "$ref": "#/definitions/successReport" },
    { "$ref": "#/definitions/credsMissingReport" },
    { "$ref": "#/definitions/pingFailReport" }
  ],
  "definitions": {
    "successReport": {
      "type": "object",
      "required": [
        "ok",
        "timestamp",
        "target",
        "runtime_env",
        "key_prefix",
        "connection",
        "summary",
        "prefixes",
        "probe"
      ],
      "additionalProperties": true,
      "properties": {
        "ok": {
          "type": "boolean",
          "description": "true om PING + probe (write/read/del) lyckades. Speglas i exit-kod."
        },
        "timestamp": { "type": "string", "format": "date-time" },
        "target": {
          "type": "string",
          "description": "Redacted REST-endpoint (t.ex. https://alert-silkworm-17000.upstash.io)."
        },
        "runtime_env": {
          "type": "string",
          "enum": ["development", "preview", "production"]
        },
        "key_prefix": {
          "type": "string",
          "pattern": "^(dev|preview|prod):$"
        },
        "connection": {
          "type": "object",
          "required": ["ok", "latency_ms"],
          "properties": {
            "ok": { "type": "boolean" },
            "latency_ms": { "type": "number", "minimum": 0 },
            "error": { "type": ["string", "null"] }
          }
        },
        "server": {
          "anyOf": [
            { "type": "null" },
            {
              "type": "object",
              "properties": {
                "redis_version": { "type": ["string", "null"] },
                "uptime_seconds": { "type": ["number", "null"] },
                "used_memory_human": { "type": ["string", "null"] },
                "connected_clients": { "type": ["number", "null"] }
              }
            }
          ]
        },
        "summary": {
          "type": "object",
          "required": ["total_keys", "total_prefix_buckets", "probe_round_trip_ms"],
          "additionalProperties": false,
          "properties": {
            "total_keys": { "type": ["integer", "null"] },
            "total_prefix_buckets": { "type": "integer", "minimum": 0 },
            "total_keys_in_buckets": { "type": "integer", "minimum": 0 },
            "probe_round_trip_ms": { "type": "number", "minimum": 0 }
          }
        },
        "prefixes": {
          "type": "array",
          "items": { "$ref": "#/definitions/prefixBucket" }
        },
        "probe": { "$ref": "#/definitions/probeResult" },
        "snapshot_error": { "type": "string" }
      }
    },
    "credsMissingReport": {
      "type": "object",
      "required": ["ok", "error", "target"],
      "additionalProperties": false,
      "properties": {
        "ok": { "type": "boolean", "enum": [false] },
        "error": { "type": "string" },
        "target": { "type": "null" }
      }
    },
    "pingFailReport": {
      "type": "object",
      "required": ["ok", "timestamp", "target", "runtime_env", "key_prefix", "connection"],
      "additionalProperties": true,
      "properties": {
        "ok": { "type": "boolean", "enum": [false] },
        "timestamp": { "type": "string", "format": "date-time" },
        "target": { "type": "string" },
        "runtime_env": {
          "type": "string",
          "enum": ["development", "preview", "production"]
        },
        "key_prefix": {
          "type": "string",
          "pattern": "^(dev|preview|prod):$"
        },
        "connection": {
          "type": "object",
          "required": ["ok", "error"],
          "properties": {
            "ok": { "type": "boolean", "enum": [false] },
            "latency_ms": { "type": "number" },
            "error": { "type": "string" }
          }
        }
      }
    },
    "prefixBucket": {
      "type": "object",
      "required": ["label", "pattern", "scope", "latency_ms"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string" },
        "pattern": { "type": "string" },
        "scope": {
          "type": "string",
          "enum": ["env", "global"],
          "description": "env = pattern är prefixad med KEY_PREFIX (siffran avser bara denna miljö). global = cross-env."
        },
        "latency_ms": { "type": "number", "minimum": 0 },
        "key_count": { "type": ["integer", "null"], "minimum": 0 },
        "sample_keys": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 3
        },
        "truncated": { "type": "boolean" },
        "error": { "type": ["string", "null"] }
      }
    },
    "probeResult": {
      "type": "object",
      "required": ["key", "write", "read", "delete"],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string" },
        "write": {
          "type": "object",
          "required": ["ok", "latency_ms"],
          "properties": {
            "ok": { "type": "boolean" },
            "latency_ms": { "type": "number", "minimum": 0 },
            "error": { "type": ["string", "null"] }
          }
        },
        "read": {
          "type": "object",
          "required": ["ok", "latency_ms", "value_matches"],
          "properties": {
            "ok": { "type": "boolean" },
            "latency_ms": { "type": "number", "minimum": 0 },
            "error": { "type": ["string", "null"] },
            "value_matches": { "type": "boolean" }
          }
        },
        "delete": {
          "type": "object",
          "required": ["ok", "latency_ms"],
          "properties": {
            "ok": { "type": "boolean" },
            "latency_ms": { "type": "number", "minimum": 0 },
            "error": { "type": ["string", "null"] }
          }
        }
      }
    }
  }
}
