{
  "name": "sajtmaskin-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.14.0 <23"
  },
  "volta": {
    "node": "22.22.2"
  },
  "scripts": {
    "preflight:common": "node scripts/dev/check-systemprompt.mjs && node scripts/dev/check-lucide-icons.mjs",
    "predev": "npm run preflight:common && npm run shadcn:sync:soft && node scripts/dev/refresh-token.mjs && node scripts/db/db-init.mjs",
    "dev": "node scripts/dev/next-runner.mjs dev",
    "dev:clean": "node scripts/dev/clean-next-cache.mjs && npm run dev",
    "refresh-token": "node scripts/dev/refresh-token.mjs",
    "prebuild": "npm run preflight:common",
    "build": "node scripts/dev/next-runner.mjs build",
    "start": "node scripts/dev/next-runner.mjs start",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "lint:fix": "eslint . --cache --cache-location .eslintcache --fix",
    "lint:watch": "npx nodemon --ext ts,tsx,js,jsx --exec \"eslint . --cache --cache-location .eslintcache --fix\"",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "devtest": "npm run typecheck && npm run scaffolds:validate && npm run test:ci && npm run lint",
    "db:init": "node scripts/db/db-init.mjs",
    "db:check": "node scripts/db/check-dev-db.mjs",
    "db:rows": "node scripts/db/db-row-overview.mjs",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:focused": "vitest run src/components/builder/BuilderMessageTooling.test.tsx src/lib/hooks/chat/helpers.test.ts src/lib/hooks/chat/post-checks.test.ts src/lib/hooks/chat/stream-handlers.test.ts src/lib/gen/stream/finalize-version.test.ts src/lib/gen/post-process/image-materializer.test.ts src/lib/gen/verify/preview-quality-gate.test.ts src/lib/gen/verify/server-verify.test.ts src/lib/providers/own-engine/generation-stream-post-finalize.test.ts src/lib/gen/eval/runner.test.ts src/lib/gen/eval/baseline.test.ts src/lib/gen/eval/scorecard.test.ts src/app/api/engine/chats/[chatId]/quality-gate/route.test.ts src/lib/integrations/tier3-build-spec.test.ts src/lib/gen/preview/warm-typecheck.test.ts src/lib/gen/autofix/rules/tier3-sdk-guard-fixer.test.ts",
    "test:openclaw:e2e": "playwright test -c playwright.openclaw.config.ts",
    "test:deploy-smoke:e2e": "playwright test -c playwright.deploy-smoke.config.ts",
    "templates:sync": "node scripts/v0-templates/sync-v0-templates.mjs",
    "templates:validate": "node scripts/v0-templates/validate-templates.mjs",
    "templates:refresh": "node scripts/v0-templates/sync-v0-templates.mjs && node scripts/v0-templates/validate-templates.mjs",
    "templates:local:refresh": "node scripts/v0-templates/refresh-local-v0-catalog.mjs",
    "templates:local:refresh:embeddings": "node scripts/v0-templates/refresh-local-v0-catalog.mjs --with-embeddings",
    "templates:embeddings": "npx tsx scripts/embeddings/generate-template-embeddings.ts",
    "scripts:dashboard": "python scripts/scripts_dashboard.py",
    "backoffice": "python sajtmaskin_backoffice.py",
    "inspector:start": "node services/inspector-worker/server.mjs",
    "inspector:install": "cd services/inspector-worker && npm install && npx playwright install chromium",
    "inspector:health": "curl -sf http://localhost:3310/health || echo UNHEALTHY",
    "inspector:docker:up": "docker compose -f infra/inspector-worker/docker-compose.yml up -d --build",
    "inspector:docker:down": "docker compose -f infra/inspector-worker/docker-compose.yml down",
    "inspector:docker:logs": "docker compose -f infra/inspector-worker/docker-compose.yml logs -f inspector-worker",
    "inspector:docker:ps": "docker compose -f infra/inspector-worker/docker-compose.yml ps",
    "scaffolds:variant-embeddings": "npx tsx scripts/scaffolds/generate-variant-embeddings.ts",
    "scaffolds:variant-patterns": "npx tsx scripts/scaffolds/auto-curate-variant-patterns.ts",
    "scaffolds:variant-patterns:dry": "npx tsx scripts/scaffolds/auto-curate-variant-patterns.ts --dry-run",
    "scaffolds:validate": "npx vitest run src/lib/gen/scaffolds/scaffold-manifest-validation.test.ts",
    "dossiers:scrape": "npx playwright test e2e/vercel-templates/scrape-catalog-light.spec.ts",
    "dossiers:enrich": "npx playwright test e2e/vercel-templates/enrich-template-details.spec.ts",
    "dossiers:import": "npx tsx scripts/dossiers/import-from-enriched.ts",
    "dossiers:index": "npx tsx scripts/dossiers/build-dossier-index.ts",
    "dossiers:embeddings": "npx tsx scripts/dossiers/generate-dossier-embeddings.ts",
    "dossiers:queue": "npx tsx scripts/dossiers/build-curation-queue.ts",
    "dossiers:promote": "npx tsx scripts/dossiers/promote-skiss-to-dossier.ts",
    "dossiers:clone-repos": "npx tsx scripts/dossiers/clone-draft-repos.ts",
    "dossiers:extract-files": "npx tsx scripts/dossiers/extract-files-from-cache.ts",
    "dossiers:curate": "npx tsx scripts/dossiers/auto-curate.ts",
    "dossiers:curate:dry": "npx tsx scripts/dossiers/auto-curate.ts --dry-run",
    "dossiers:recommend": "npx tsx scripts/dossiers/build-scaffold-recommendations.ts",
    "dossiers:recommend:merge": "npx tsx scripts/dossiers/build-scaffold-recommendations.ts --merge",
    "dossiers:recommend:force": "npx tsx scripts/dossiers/build-scaffold-recommendations.ts --force",
    "dossiers:compat": "npx tsx scripts/dossiers/compat-test.ts",
    "dossiers:compat:apply": "npx tsx scripts/dossiers/compat-test.ts --apply",
    "dossiers:github-enrich": "npx tsx scripts/dossiers/enrich-with-github-api.ts",
    "dossiers:rebuild": "npm run dossiers:index && npm run dossiers:recommend:merge && npm run dossiers:embeddings",
    "dossiers:full-pipeline": "npx tsx scripts/dossiers/run-full-pipeline.ts",
    "dossiers:smoke-prompt": "npx tsx scripts/dossiers/smoke-prompt.ts",
    "shadcn:sync": "npx tsx scripts/shadcn/sync-shadcn-registry.ts",
    "shadcn:sync:soft": "npm run shadcn:sync || echo [shadcn-sync] Registry check skipped",
    "shadcn:sync:write": "npx tsx scripts/shadcn/sync-shadcn-registry.ts --write",
    "shadcn:sync-examples": "npx tsx scripts/shadcn/sync-shadcn-examples.ts",
    "baseline-deps:verify": "npx tsx scripts/deps/validate-baseline-npm-versions.ts",
    "baseline-deps:tree": "npx tsx scripts/deps/validate-baseline-npm-tree.ts",
    "eval": "npx tsx scripts/eval/run-eval.ts",
    "eval:suite": "npx tsx src/lib/gen/eval/cli.ts",
    "eval:gate": "npx tsx src/lib/gen/eval/cli.ts --gate",
    "eval:baseline": "npx tsx src/lib/gen/eval/cli.ts --save-baseline",
    "db:migrate": "npx tsx scripts/db/run-migrations.ts",
    "db:push": "node scripts/db/db-push.mjs",
    "db:generate": "npx drizzle-kit generate",
    "vercel:link": "vercel link",
    "env:status": "python scripts/env/manage_env.py status",
    "env:audit": "python scripts/env/manage_env.py audit",
    "env:audit:strict": "python scripts/env/manage_env.py audit --strict",
    "env:reconcile": "python scripts/env/manage_env.py reconcile",
    "env:pull": "vercel env pull .env.local --yes",
    "env:pull:prod-snapshot": "vercel env pull .env.vercel.production.pulled --environment production --yes",
    "mirror:audit": "node scripts/audit/audit-shadcn-mirror-repos.mjs",
    "mirror:audit:verbose": "node scripts/audit/audit-shadcn-mirror-repos.mjs --verbose",
    "mirror:audit:json": "node scripts/audit/audit-shadcn-mirror-repos.mjs --json",
    "mirror:audit:strict": "node scripts/audit/audit-shadcn-mirror-repos.mjs --strict"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.18",
    "@base-ui/react": "^1.2.0",
    "@d-id/client-sdk": "^1.1.52",
    "@hookform/resolvers": "^5.2.2",
    "@paper-design/shaders-react": "^0.0.71",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@react-three/rapier": "^2.2.0",
    "@streamdown/code": "^1.1.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-table": "^8.21.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.3.1",
    "@vercel/speed-insights": "^1.3.1",
    "@xyflow/react": "^12.10.0",
    "ai": "^6.0.69",
    "cheerio": "^1.0.0-rc.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.29.0",
    "input-otp": "^1.4.2",
    "ioredis": "^5.9.2",
    "jszip": "^3.10.1",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.563.0",
    "ms": "^2.1.3",
    "nanoid": "^5.1.6",
    "next": "^16.1.4",
    "next-themes": "^0.4.6",
    "openai": "^6.16.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.17.2",
    "postcss": "^8.5.1",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.7.2",
    "react-syntax-highlighter": "^16.1.0",
    "recharts": "^2.15.4",
    "resend": "^6.9.1",
    "sonner": "^2.0.7",
    "streamdown": "^2.4.0",
    "stripe": "^20.2.0",
    "swr": "^2.3.8",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "three": "^0.182.0",
    "tokenlens": "^1.3.1",
    "typescript": "5.9.3",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^0.1.0",
    "@eslint/js": "^9.39.2",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/google.maps": "^3.58.1",
    "@types/jszip": "^3.4.0",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.0.10",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.0.1",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^5.1.4",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.1.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.20.5",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@vercel/fun": "1.3.0",
    "@vercel/node": {
      "path-to-regexp": "6.3.0",
      "undici": "6.23.0"
    },
    "@vercel/remix-builder": {
      "path-to-regexp": "6.3.0"
    },
    "esbuild": "^0.25.0"
  }
}
