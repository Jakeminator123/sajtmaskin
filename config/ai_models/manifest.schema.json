{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sajtmaskin.local/config/ai_models/manifest.schema.json",
  "title": "Sajtmaskin AI models manifest",
  "type": "object",
  "required": ["schemaVersion", "buildProfiles", "promptAssist", "briefing", "phaseRouting", "repairPolicies", "promptOrchestration", "postGenerationPasses", "preGenerationContracts", "tokenBudgets", "routeTimeouts", "workloads"],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "documentationDirectApiNote": {
      "type": "string",
      "description": "Explains that vendor docs marked direct_provider_api target direct provider APIs."
    },
    "docLinks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["vendor", "title", "url"],
        "properties": {
          "vendor": { "type": "string" },
          "title": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "appliesTo": {
            "type": "string",
            "enum": ["direct_provider_api", "sdk_or_tooling"]
          }
        }
      }
    },
    "buildProfiles": {
      "type": "object",
      "required": ["defaults", "envKeys"],
      "properties": {
        "defaults": {
          "type": "object",
          "required": ["fast", "pro", "max", "codex", "anthropic"],
          "additionalProperties": { "type": "string" }
        },
        "envKeys": {
          "type": "object",
          "required": ["fast", "pro", "max", "codex", "anthropic"],
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "qualityToOwnEngineModel": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "promptAssist": { "type": "object" },
    "briefing": {
      "type": "object",
      "required": ["defaults", "envKeys"],
      "properties": {
        "defaults": {
          "type": "object",
          "required": ["requestModel", "serverAutoOpenAI", "serverAutoAnthropic", "specModel"],
          "properties": {
            "requestModel": { "type": "string" },
            "serverAutoOpenAI": { "type": "string" },
            "serverAutoAnthropic": { "type": "string" },
            "specModel": { "type": "string" }
          }
        },
        "envKeys": {
          "type": "object",
          "required": ["requestModel", "serverAutoOpenAI", "serverAutoAnthropic", "specModel"],
          "properties": {
            "requestModel": { "type": "string" },
            "serverAutoOpenAI": { "type": "string" },
            "serverAutoAnthropic": { "type": "string" },
            "specModel": { "type": "string" }
          }
        },
        "notes": { "type": "string" }
      }
    },
    "phaseRouting": {
      "type": "object",
      "required": ["defaultByTier"],
      "properties": {
        "defaultByTier": {
          "type": "object",
          "required": ["fast", "pro", "max", "codex", "anthropic"],
          "properties": {
            "fast": { "$ref": "#/$defs/phaseRoutingTier" },
            "pro": { "$ref": "#/$defs/phaseRoutingTier" },
            "max": { "$ref": "#/$defs/phaseRoutingTier" },
            "codex": { "$ref": "#/$defs/phaseRoutingTier" },
            "anthropic": { "$ref": "#/$defs/phaseRoutingTier" }
          }
        },
        "notes": { "type": "string" }
      }
    },
    "repairPolicies": {
      "type": "object",
      "required": ["deterministicAutofixPasses", "syntaxFixPasses", "manualRepairRouteLlmPasses", "serverRepairPasses"],
      "properties": {
        "deterministicAutofixPasses": { "type": "integer", "minimum": 1, "maximum": 10 },
        "syntaxFixPasses": { "type": "integer", "minimum": 1, "maximum": 10 },
        "manualRepairRouteLlmPasses": { "type": "integer", "minimum": 1, "maximum": 10 },
        "serverRepairPasses": { "type": "integer", "minimum": 1, "maximum": 10 }
      }
    },
    "promptOrchestration": {
      "type": "object",
      "required": ["hardCaps", "softTargets", "phaseThresholds"],
      "properties": {
        "hardCaps": {
          "type": "object",
          "required": [
            "maxChatMessageChars",
            "warnChatMessageChars",
            "maxChatSystemChars",
            "warnChatSystemChars",
            "maxPromptHandoffChars",
            "maxAiBriefPromptChars",
            "maxAiChatMessageChars",
            "maxAiSpecPromptChars"
          ],
          "additionalProperties": false,
          "properties": {
            "maxChatMessageChars": { "$ref": "#/$defs/numericEnvSetting" },
            "warnChatMessageChars": { "$ref": "#/$defs/numericEnvSetting" },
            "maxChatSystemChars": { "$ref": "#/$defs/numericEnvSetting" },
            "warnChatSystemChars": { "$ref": "#/$defs/numericEnvSetting" },
            "maxPromptHandoffChars": { "$ref": "#/$defs/numericEnvSetting" },
            "maxAiBriefPromptChars": { "$ref": "#/$defs/numericEnvSetting" },
            "maxAiChatMessageChars": { "$ref": "#/$defs/numericEnvSetting" },
            "maxAiSpecPromptChars": { "$ref": "#/$defs/numericEnvSetting" }
          }
        },
        "softTargets": {
          "type": "object",
          "required": [
            "freeformChars",
            "wizardChars",
            "auditChars",
            "templateChars",
            "followupChars",
            "technicalChars",
            "appChars"
          ],
          "additionalProperties": false,
          "properties": {
            "freeformChars": { "$ref": "#/$defs/numericEnvSetting" },
            "wizardChars": { "$ref": "#/$defs/numericEnvSetting" },
            "auditChars": { "$ref": "#/$defs/numericEnvSetting" },
            "templateChars": { "$ref": "#/$defs/numericEnvSetting" },
            "followupChars": { "$ref": "#/$defs/numericEnvSetting" },
            "technicalChars": { "$ref": "#/$defs/numericEnvSetting" },
            "appChars": { "$ref": "#/$defs/numericEnvSetting" }
          }
        },
        "phaseThresholds": {
          "type": "object",
          "required": ["defaultChars", "auditChars"],
          "additionalProperties": false,
          "properties": {
            "defaultChars": { "$ref": "#/$defs/numericEnvSetting" },
            "auditChars": { "$ref": "#/$defs/numericEnvSetting" }
          }
        }
      }
    },
    "postGenerationPasses": {
      "type": "object",
      "required": [
        "polishMaxOutputTokens",
        "polishTimeoutMs",
        "polishMaxFilesWhenUnscoped",
        "verifierMaxOutputTokens",
        "verifierTimeoutMs",
        "verifierSnippetCharsPerFile"
      ],
      "additionalProperties": false,
      "properties": {
        "polishMaxOutputTokens": { "$ref": "#/$defs/numericEnvSetting" },
        "polishTimeoutMs": { "$ref": "#/$defs/numericEnvSetting" },
        "polishMaxFilesWhenUnscoped": { "$ref": "#/$defs/numericEnvSetting" },
        "verifierMaxOutputTokens": { "$ref": "#/$defs/numericEnvSetting" },
        "verifierTimeoutMs": { "$ref": "#/$defs/numericEnvSetting" },
        "verifierSnippetCharsPerFile": { "$ref": "#/$defs/numericEnvSetting" }
      }
    },
    "preGenerationContracts": {
      "type": "object",
      "required": ["defaults", "providerRules"],
      "properties": {
        "defaults": {
          "type": "object",
          "required": [
            "fallbackDatabaseProvider",
            "fallbackAuthProvider",
            "fallbackPaymentProvider"
          ],
          "properties": {
            "fallbackDatabaseProvider": { "type": "string" },
            "fallbackAuthProvider": { "type": "string" },
            "fallbackPaymentProvider": { "type": "string" }
          }
        },
        "providerRules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "kind",
              "provider",
              "name",
              "envVars",
              "matchPatterns",
              "reason"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["database", "auth", "payment", "integration"]
              },
              "provider": { "type": "string" },
              "name": { "type": "string" },
              "envVars": { "type": "array", "items": { "type": "string" } },
              "matchPatterns": { "type": "array", "items": { "type": "string" } },
              "status": { "type": "string", "enum": ["chosen", "optional"] },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "tokenBudgets": { "type": "object" },
    "routeTimeouts": { "type": "object" },
    "embeddingModels": { "type": "object" },
    "generatedSiteIntegrationPlaceholders": {
      "type": "object",
      "description": "Plain-text env fragment for generated user-site preview builds (not Sajtmaskin app env).",
      "required": ["envFragmentFile"],
      "properties": {
        "envFragmentFile": {
          "type": "string",
          "description": "Filename under config/ai_models/ (dotenv-style KEY=value)."
        },
        "policyDocRelativeToConfig": { "type": "string" },
        "preGenerationContractsEntry": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "workloads": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "invocation", "provider", "codeEntry", "authEnv"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "invocation": { "type": "string" },
          "provider": { "type": "string" },
          "codeEntry": { "type": "array", "items": { "type": "string" } },
          "authEnv": { "type": "array", "items": { "type": "string" } },
          "defaultModel": { "type": "string" },
          "fallbackModels": { "type": "array", "items": { "type": "string" } },
          "envOverrides": { "type": "object", "additionalProperties": { "type": "string" } },
          "tokenBudget": {
            "type": "object",
            "required": ["envKey", "default", "min", "max"],
            "properties": {
              "envKey": { "type": "string" },
              "default": { "type": "number" },
              "min": { "type": "number" },
              "max": { "type": "number" }
            }
          },
          "notes": { "type": "string" },
          "anthropicModelIdNormalization": { "type": "string" },
          "docLinks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["vendor", "title", "url"],
              "properties": {
                "vendor": { "type": "string" },
                "title": { "type": "string" },
                "url": { "type": "string" },
                "appliesTo": {
                  "type": "string",
                  "enum": ["direct_provider_api", "sdk_or_tooling"]
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "numericEnvSetting": {
      "type": "object",
      "required": ["envKey", "default", "min", "max"],
      "properties": {
        "envKey": { "type": "string" },
        "default": { "type": "number" },
        "min": { "type": "number" },
        "max": { "type": "number" }
      }
    },
    "phaseRoutingTier": {
      "type": "object",
      "required": ["planner", "generator", "fixer", "verifier", "deploy-assistant"],
      "properties": {
        "planner": { "type": "string" },
        "generator": { "type": "string" },
        "fixer": { "type": "string" },
        "verifier": { "type": "string" },
        "deploy-assistant": { "type": "string" }
      }
    }
  }
}
