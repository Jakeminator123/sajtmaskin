{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dossier.schema.json",
  "title": "Dossier",
  "description": "A scaffold-agnostic lego brick: an integration (third-party provider) or a UI-section pattern. Source of truth: docs/architecture/dossier-format.md",
  "type": "object",
  "required": [
    "id",
    "kind",
    "category",
    "label",
    "description",
    "summary",
    "dependencies",
    "files",
    "scaffoldFit",
    "complexity",
    "lastVerified",
    "tags",
    "_source"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Kebab-case unique id. Must match the directory name."
    },
    "kind": {
      "type": "string",
      "enum": ["integration", "ui-section"],
      "description": "integration = ties to a third-party provider; ui-section = pure UI building block."
    },
    "category": {
      "type": "string",
      "enum": [
        "payments",
        "auth",
        "database",
        "cms",
        "realtime",
        "bookings",
        "email",
        "analytics",
        "ai",
        "search",
        "storage",
        "ui-marketing",
        "ui-content",
        "ui-data",
        "ui-navigation",
        "ui-feedback"
      ]
    },
    "label": { "type": "string", "minLength": 2, "maxLength": 80 },
    "description": { "type": "string", "minLength": 10, "maxLength": 200 },
    "summary": { "type": "string", "minLength": 30, "maxLength": 600 },
    "providers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        }
      }
    },
    "envVars": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "required", "purpose"],
        "additionalProperties": false,
        "properties": {
          "key": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
          "required": { "type": "boolean" },
          "purpose": { "type": "string", "minLength": 10 }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "npm package names that must be added to package.json"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "role", "kind"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string", "pattern": "^components/" },
          "role": { "type": "string", "enum": ["client", "server", "shared"] },
          "kind": {
            "type": "string",
            "enum": ["component", "api-route", "hook", "util", "config", "middleware"]
          }
        }
      }
    },
    "exposes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "import"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["component", "function", "hook", "constant"] },
          "import": { "type": "string" }
        }
      }
    },
    "scaffoldFit": {
      "type": "object",
      "description": "Soft ranking hint, not a filter. All dossiers are available to all scaffolds. `primary` boosts embedding rank by ~+0.15, `compatible` by ~+0.05.",
      "required": ["primary", "compatible"],
      "additionalProperties": false,
      "properties": {
        "primary": { "type": "array", "items": { "type": "string" } },
        "compatible": { "type": "array", "items": { "type": "string" } }
      }
    },
    "_source": {
      "type": "string",
      "description": "Where this dossier came from. Free-form but use stable values: hand-curated, vercel-light-catalog, shadcn-blocks, manual-import, etc."
    },
    "complexity": { "type": "string", "enum": ["simple", "medium", "advanced"] },
    "qualityScore": { "type": "integer", "minimum": 0, "maximum": 100 },
    "sourceTemplateUrl": { "type": "string", "format": "uri" },
    "sourceRepoUrl": { "type": "string", "format": "uri" },
    "lastVerified": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "maxItems": 12
    },
    "_status": {
      "type": "string",
      "enum": ["draft", "active"],
      "description": "Lifecycle. Drafts are filtered out at runtime; only active dossiers are matched against prompts."
    },
    "_curatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp when the dossier was last finalized (hand or auto)."
    },
    "_curatedBy": {
      "type": "string",
      "description": "Who or what produced this dossier. Examples: 'hand', 'auto-curate.ts', '<github-username>'."
    },
    "_extractedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Set by extract-files-from-cache.ts. Cleared once dossier is curated."
    },
    "_extractedFromCache": {
      "type": "boolean",
      "description": "Set by extract-files-from-cache.ts. Cleared once dossier is curated."
    },
    "_envExampleCopied": {
      "type": "boolean",
      "description": "Set by extract-files-from-cache.ts. Cleared once dossier is curated."
    }
  }
}
