# =============================================================================
# SAJTMASKIN .gitignore
# =============================================================================

# Python bytecode
__pycache__/
*.pyc

# Node/Next.js
node_modules/
node_modules.old/
.next/
.next/dev/cache/
.next/dev/node_modules/
out/
.cache/
dist/
build/
coverage/

# Generated files (recreated on build)
tsconfig.tsbuildinfo
next-env.d.ts

# ESLint persistent cache (per-machine; speeds up `npm run lint` 5-10x)
.eslintcache

# Environment files (NEVER commit secrets!)
# .env.* covers .env.local, .env.production.local, etc.
.env
.env.*
!.env.example
!.env.*.example
# Renamed snapshots used for diffing against Vercel — often contain real secrets
OLD.env*
# Same policy: manual exports / zip restores sometimes omit the leading dot (`env.*` not `.env.*`)
env.vercel*.local
*.env.backup
*.env.bak
*.pem
*key
.env.production
.token-status.json

# Local notes / chat dumps (keep secrets and noise out of git)
ENV_JAMFORRELSE.txt
di-d.txt

# Temp commit-message files from local commit workflow
COMMIT_MSG.tmp
COMMIT_EDITMSG.tmp

# Lokala tmp-dumpar (t.ex. accidental API-responsfångster)
.tmp-*

# Local prompt dumps (opt-in: SAJTMASKIN_PROMPT_DUMP=1)
data/prompt-dumps/*
!data/prompt-dumps/README.md

# Pipeline-health-state (backoffice-paneldata, lokalt per-maskin)
data/backoffice/

# Database files (local data, not for git)
data/*.db
data/*.db-shm
data/*.db-wal
data/uploads/

# Runtime observability artefacts (error-log RAG index, etc.)
# Per-machine; rebuild via `npm run rag:error-log:reindex` or auto-ingest hook.
data/observability/

# Lokalt arkiv (labs, gamla scripts) — håll borta från git-status
/archive/

# testning_scarf-output (om du återställer scripts utanför /archive/)
archive/scripts-labs-testning_scarf/output/
archive/scripts-labs-testning_scarf/output_test_scaffold/
archive/scripts-labs-testning_scarf/output_first_llm_underlag/
# Legacy (före samlad output-mapp)
scripts/output_test_scaffold/

# Local generation comparisons (manual API runs)
output/generations/

# --- Genererade artefakter (stora JSON / embeddings — minskar index-kontext; återskapas av scripts) ---
src/lib/gen/scaffolds/scaffold-embeddings.json
src/lib/gen/scaffolds/scaffold-research.generated.json
src/lib/gen/template-library/template-library-embeddings.json
src/lib/gen/template-library/template-library.generated.json

# --- Canonical external-template pipeline (local mutable data) ---
data/external-template-pipeline/scrape-cache/**
data/external-template-pipeline/raw-discovery/**
data/external-template-pipeline/repo-cache/**
data/external-template-pipeline/reference-library/**
data/external-template-pipeline/reports/**

# run-eval / codegen harness markdown output (scripts/eval/run-eval.ts)
eval-output/
# Legacy output dir (rename → eval-output/); safe to delete locally
EGEN_MOTOR_V2/

# Legacy Vercel template scrape roots (replaced by data/external-template-pipeline/)
scraped-vercel-scorefolds/
# Äldre syskon-/rotmål ska inte användas som canonical paths längre.
sajtmaskin-template-cache/
vercel-scrape/
vercel-scrape-fresh/

# Playwright Vercel catalog tooling — lokal granskning; tillfälligt utanför git (finns i roten om du återställt den)
vercel_templates_levels/

# MCP scraped documentation (60+ MB, regenerate with doc.py)
services/mpc/docs/docgrab__*/
services/mpc/docs/local/
services/mpc/docs/*llms*
services/mpc/docs/SDK_6.md
services/mpc/docs/shad/
services/mpc/logs/

# Editor/OS
.idea/
.DS_Store
Thumbs.db
# Cursor-specific (plans are session-specific, mcp.json is shared)
.cursor/plans/
.cursor/documents/
# Local MCP config (can hold tokens); committed template: .cursor/mcp.json.example
.cursor/mcp.json

# OAuth / mobile secret dumps (never commit real files)
**/client_secret*.json
google-services.json

# --- Cursor session / automation / migration ---
.cursor/automation/runs/
.cursor/automation/archive/
.cursor/automation/input/
.cursor/migration-archive/
# Lokal mirror av buggrapporter via /buggrapport (Linear är källan-till-sanning).
# README:n committas så konventionen är synlig för agenter på andra maskiner.
.cursor/bugs/*
!.cursor/bugs/README.md
.cursor/handoffs/*
!.cursor/handoffs/README.md

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
mcp-monitoring-report.txt
# logs/ innehåller runtime-artefakter (NDJSON/CSV/JSON som växer per körning).
# Capping/retention sker i src/lib/logging/generation-log-writer.ts:
#   - generationslogg/<run>/   max 15 mappar
#   - site-observability/<chat>/ max 30 mappar (LRU)
#   - generationslogg/_unrouted/<bucket>/ max 10 mappar (LRU)
#   - llm-segmentts-and-index/error-log.csv   max 2000 rader
logs/*
manual_log/
input_files_for_cursor/logg_*.txt
DOM_dev_tols.txt
chat_till_vanster.txt
logg.txt

# Temp/dev files
.preprompt_history.json
.cursor/openclaw-bridge-message.txt
övrigt
skrapning
/[{]*.png
_env.production
_env.development

# Avoid accidentally committing a nested clone/repo
sajtgen
_template_refs/

# Large local docs/specs (keep out of git unless intentionally added)
SiteStudio_Projektspecifikation_ifillningsbar_v2.pdf
Arkitektur och teknikstack.pdf
ANALYS-*.txt
next_sidan_skrapning.txt

# Local env dumps (often contain secrets)
environments.production
vercel-env-deploy.txt
git_env.txt

/old/
senaste_miljovariablar/
sajtmaskin.code-workspace

# Archived secret dumps should never be versioned
docs/old/**/*.env.local
docs/old/**/*.env.production
docs/old/**/*.env
docs/old/**/*env*.txt

# Vercel
.vercel

# Automation kit + cursor-gpt local artifacts (local-only)
.cursor/agents/
.cursor/rules/automation-safety.mdc
automation/
.automation/
.cursor-gpt-kit/
config.txt
config.browser.txt
config.example.txt
INSTALERA.py
INSTALLERA.py
automation/state/run-state.json
automation/state/ui-dashboard/
automation/inbox/deep-research-report*.md
automation/inbox/tmp-*
automation/runtime/browser-input-*.md
automation/packets/iteration-*/
automation/reports/iteration-*/
automation/reports/browser-run-iteration-*.json
automation/reports/final-summary.md
automation/reports/final-summary.json
playwright-report/


test-results/
_scaffold_discovery/


# --- Legacy research intake roots (retired; keep out of git if they still exist locally) ---
research/external-templates/raw-discovery/**
research/external-templates/repo-cache/**
research/external-templates/reference-library/


_sidor/
research/_sidor/
_input_for_cursor/
STOR_MIGRATION

.env*.local
files_envvars

# Temp analysis files (not part of codebase)
VISUAL-DESIGN-PROMPT-BRA-*.txt
SCARFOLDS_ALTERNATIV/
historik_agenter.txt
UTLÅTANDE_DEEP_BREEF.txt

# OpenClaw bridge (local agent communication, never commit)
.cursor/openclaw-bridge/
sajtmaskin.zip


