[
  {
    "namespace": "@shadcnblocks",
    "url": "https://shadcnblocks.com/r/{name}.json",
    "description": "Marketing blocks: hero, features, pricing, CTA, testimonials, FAQ, footer, navbar, contact, about",
    "maxPerGeneration": 2,
    "sectionMappings": {
      "hero": ["hero1", "hero3", "hero5"],
      "features": ["feature1", "feature3", "feature5"],
      "pricing": ["pricing1", "pricing3"],
      "testimonials": ["testimonial1", "testimonial3"],
      "cta": ["cta1", "cta3"],
      "faq": ["faq1", "faq2"],
      "footer": ["footer1", "footer3"],
      "navbar": ["navbar1"],
      "contact": ["contact1"],
      "about": ["about1"],
      "stats": ["stats1"]
    }
  },
  {
    "namespace": "@tailark",
    "url": "https://tailark.com/r/{name}.json",
    "description": "Clean marketing website blocks (verified against live registry 2026-04)",
    "maxPerGeneration": 1,
    "sectionMappings": {
      "hero": ["hero-section-1", "hero-section-2", "hero-section-3", "hero-section-4", "hero-section-5"],
      "features": ["features-1", "features-2", "features-3", "features-4", "features-5"],
      "pricing": ["pricing-1", "pricing-2", "pricing-3", "pricing-4"],
      "cta": ["call-to-action-1", "call-to-action-2", "call-to-action-3"],
      "faq": ["faqs-1", "faqs-2", "faqs-3", "faqs-4"],
      "footer": ["footer-1", "footer-2", "footer-3", "footer-4", "footer-5"],
      "testimonials": ["testimonials-1", "testimonials-2", "testimonials-3", "testimonials-4"],
      "contact": ["contact-1", "contact-2"],
      "team": ["team-1", "team-2"],
      "stats": ["stats-1", "stats-2", "stats-3", "stats-4"]
    }
  },
  {
    "namespace": "@magicui",
    "url": "https://magicui.design/r/{name}",
    "description": "Animated UI effects",
    "maxPerGeneration": 1,
    "sectionMappings": {
      "animation": ["marquee", "bento-grid", "shimmer-button", "number-ticker", "animated-list"],
      "background": ["particles", "dot-pattern", "grid-pattern", "retro-grid"],
      "premium": ["magic-card", "neon-gradient-card", "meteors", "globe"]
    }
  }
]
