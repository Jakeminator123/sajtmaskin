# =============================================================================
# SAJTMASKIN .gitignore
# =============================================================================

# Python bytecode
__pycache__/
*.pyc

# Node/Next.js
node_modules/
.next/
out/
.cache/
dist/
build/
coverage/

# Generated files (recreated on build)
tsconfig.tsbuildinfo
next-env.d.ts

# Environment files (NEVER commit secrets!)
.env
.env.*
.env.local
*.pem
*key
.env.production
.token-status.json

# Database files (local data, not for git)
data/*.db
data/*.db-shm
data/*.db-wal
data/uploads/

# Local generated reports (recreate from scripts when needed)
data/scaffold-candidates-curated.json

# MCP scraped documentation (60+ MB, regenerate with doc.py)
services/mpc/docs/docgrab__*/
services/mpc/docs/local/
services/mpc/docs/*llms*
services/mpc/docs/SDK_6.md
services/mpc/docs/shad/
services/mpc/logs/

# Editor/OS
.idea/
.DS_Store
Thumbs.db
# Cursor-specific (plans are session-specific, mcp.json is shared)
.cursor/plans/
.cursor/documents/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
mcp-monitoring-report.txt
logs/
manual_log/
input_files_for_cursor/logg_*.txt
DOM_dev_tols.txt
chat_till_vanster.txt

# Temp/dev files
.preprompt_history.json
övrigt
skrapning
/[{]*.png
_env.production
_env.development

# Avoid accidentally committing a nested clone/repo
sajtgen
_template_refs/

# Large local docs/specs (keep out of git unless intentionally added)
SiteStudio_Projektspecifikation_ifillningsbar_v2.pdf
Arkitektur och teknikstack.pdf
ANALYS-*.txt
next_sidan_skrapning.txt

# Local env dumps (often contain secrets)
environments.production
vercel-env-deploy.txt
git_env.txt

/old/
senaste_miljovariablar/
sajtmaskin.code-workspace

# Archived secret dumps should never be versioned
docs/old/**/*.env.local
docs/old/**/*.env.production
docs/old/**/*.env
docs/old/**/*env*.txt

# Automation kit (local-only)
automation/
.automation/
.cursor-gpt-kit/
config.txt
config.browser.txt
config.example.txt
INSTALERA.py
INSTALLERA.py

# Vercel
.vercel



# >>> cursor-gpt automation local artifacts >>>
.cursor/agents/
.cursor/rules/automation-safety.mdc
automation/
config.txt
config.example.txt
config.browser.txt
INSTALLERA.py
INSTALERA.py
.cursor-gpt-kit/
