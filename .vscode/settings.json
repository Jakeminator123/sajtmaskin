{
  "markdownlint.ignore": [
    "**/node_modules/**",
    "**/.git/**",
    "**/.next/**",
    "**/out/**",
    "**/build/**",
    "**/dist/**",
    "**/coverage/**",
    "**/research/**",
    "**/pot_buggs/**",
    "**/src/templates/**",
    "**/.cursor/**",
    "templates_v0/**",
    "data/template-references/repos/**",
    "data/external-template-pipeline/repo-cache/**",
    "data/dossiers/_repo-cache/**"
  ],

  "editor.formatOnSave": false,
  "editor.tabSize": 2,

  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },

  "eslint.useFlatConfig": true,

  "files.eol": "\n",
  "files.autoSave": "off",

  "files.exclude": {
    "**/.git": true,
    "**/.next": true,
    "**/node_modules": true,
    "templates_v0/**": true,
    "data/template-references/repos/**": true,
    "data/external-template-pipeline/repo-cache/**": true,
    "data/dossiers/_repo-cache/**": true
  },

  "search.exclude": {
    "**/.git": true,
    "**/.next": true,
    "**/node_modules": true,
    "**/out": true,
    "**/build": true,
    "**/dist": true,
    "templates_v0/**": true,
    "data/template-references/repos/**": true,
    "data/external-template-pipeline/repo-cache/**": true,
    "data/dossiers/_repo-cache/**": true
  },

  "files.watcherExclude": {
    "**/.git/**": true,
    "**/.next/**": true,
    "**/node_modules/**": true,
    "**/out/**": true,
    "**/build/**": true,
    "**/dist/**": true,
    "templates_v0/**": true,
    "data/template-references/repos/**": true,
    "data/external-template-pipeline/repo-cache/**": true,
    "data/dossiers/_repo-cache/**": true
  },

  "search.useIgnoreFiles": true,
  "search.useGlobalIgnoreFiles": true,
  "search.useParentIgnoreFiles": true,

  "typescript.tsserver.experimental.enableProjectDiagnostics": false,

  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },

  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cn\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"]
  ],

  "git.autofetch": true,

  "terminal.integrated.defaultProfile.windows": "PowerShell 7",

  "terminal.integrated.profiles.windows": {
    "PowerShell 7": {
      "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
      "args": ["-NoLogo"],
      "icon": "terminal-powershell"
    }
  },

  "terminal.integrated.automationProfile.windows": {
    "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
    "args": ["-NoLogo", "-NoProfile"]
  },

  "terminal.integrated.env.windows": {
    "PATH": "${env:LOCALAPPDATA}\\Volta\\bin;C:\\Program Files\\Volta;${env:LOCALAPPDATA}\\cursor-agent;${env:PATH}"
  }
}
