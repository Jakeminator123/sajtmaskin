{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@viewser/*": [
        "./src/viewser/*"
      ],
      "@preview-runtime": [
        "./src/viewser/lib/preview-runtime/index"
      ],
      "@preview-runtime/*": [
        "./src/viewser/lib/preview-runtime/*"
      ]
    },
    "target": "ES2022",
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "data/eval-runs",
    "data/external-template-pipeline",
    "data/dossiers",
    "data/template-references",
    "archive",
    "ai-fal-image-generator",
    "output",
    "src/templates",
    "src/lib/gen/scaffolds/*/files",
    "drizzle.config.ts",
    "old",
    "_template_refs",
    "e2e",
    "vercel_templates_levels",
    "research",
    "övrigt/testyta",
    "test_scarfold_foto"
  ]
}
