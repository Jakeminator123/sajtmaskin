{
  "$schema": "../../../docs/schemas/strict/dossier.schema.json",
  "id": "auth-next-js-prisma-postgres-auth-starter",
  "kind": "integration",
  "category": "auth",
  "label": "Next.js & Prisma Postgres Auth Starter",
  "description": "Get started with Next.js, Prisma Postgres, and Auth.js",
  "summary": "Use this dossier when a Next.js app needs email/password authentication backed by Auth.js sessions and a Prisma-managed Postgres database. It provides the Auth.js route handler, Prisma client setup for Prisma Postgres, and the core patterns needed to add credentials auth, session access, and protected server logic.",
  "providers": [
    {
      "name": "Auth.js",
      "url": "https://github.com/prisma/nextjs-auth-starter"
    }
  ],
  "envVars": [
    {
      "key": "DATABASE_URL",
      "required": true,
      "purpose": "Or manually run `npx prisma init --db` to create a Prisma Postgres and manually set the `DATABASE_URL` below"
    },
    {
      "key": "AUTH_SECRET",
      "required": true,
      "purpose": "Create a random 32-character string or run `npx auth secret` to obtain one and set it as the `AUTH_SECRET` below"
    }
  ],
  "dependencies": [
    "@prisma/adapter-pg",
    "@prisma/client",
    "bcryptjs",
    "lucide-react",
    "next-auth"
  ],
  "files": [
    {
      "path": "components/app/api/auth/[...nextauth]/route.ts",
      "role": "server",
      "kind": "api-route"
    },
    {
      "path": "components/lib/prisma.ts",
      "role": "server",
      "kind": "util"
    },
    {
      "path": "components/auth.ts",
      "role": "server",
      "kind": "config"
    },
    {
