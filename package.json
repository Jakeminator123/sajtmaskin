    "eslint-config-prettier": "^10.1.0",
    "globals": "^17.1.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "vitest": "^4.0.18"
  },
  "overrides": {
