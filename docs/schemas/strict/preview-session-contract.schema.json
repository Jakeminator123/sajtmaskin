{
  "$schemaVersion": 1,
  "id": "preview-session-contract",
  "title": "Preview session and verify-lane contract",
  "kind": "strict_contract",
  "sourceOfTruth": {
    "types": [
      "src/lib/gen/preview/preview-contract.ts",
      "src/lib/gen/preview/preview-host-client.ts",
      "src/lib/integrations/tier3-build-spec.ts",
      "src/lib/integrations/placeholder-harmless.ts"
    ],
    "runtime": [
      "src/lib/gen/verify/preview-quality-gate.ts",
      "src/lib/gen/verify/server-verify.ts",
      "src/app/api/engine/chats/[chatId]/quality-gate/route.ts",
      "src/app/api/engine/chats/[chatId]/repair/route.ts",
      "src/app/api/engine/chats/[chatId]/accept-repair/route.ts",
      "src/app/api/engine/chats/[chatId]/finalize-design/route.ts",
      "src/lib/db/chat-repository-pg.ts",
      "preview-host/src/server.js",
      "preview-host/src/validate.js",
      "preview-host/src/runtime.js"
    ],
    "humanDoc": "docs/schemas/preview-session-contract.md"
  },
  "identifiers": {
    "appProjectId": {
      "type": "string",
      "canonical": true,
      "layer": "builder/app state",
      "meaning": "Durable Sajtmaskin project ID",
      "mustNotBeConfusedWith": ["chatId", "VERCEL_PROJECT_ID"]
    },
    "chatId": {
      "type": "string",
      "canonical": true,
      "layer": "own-engine and preview lane",
      "meaning": "Durable own-engine chat ID and current preview-host runtime key",
      "previewHostPathKey": true
    },
    "versionId": {
      "type": "string",
      "canonical": true,
      "layer": "version state",
      "meaning": "Specific saved version within a chat"
    },
    "previewSessionId": {
      "type": "string",
      "canonical": true,
      "layer": "tier-2 runtime/session",
      "meaning": "Active tier-2 preview session ID",
      "legacyAliases": ["sandboxId"]
    },
    "previewUrl": {
      "type": "string",
      "canonical": true,
      "layer": "public preview",
      "meaning": "Public preview URL",
      "dbColumn": "engine_versions.preview_url",
      "legacyAliases": ["sandboxUrl"]
    },
    "runId": {
      "type": "string",
      "canonical": true,
      "layer": "observability",
      "meaning": "Observability/log run identifier"
    },
    "VERCEL_PROJECT_ID": {
      "type": "string",
      "canonical": true,
      "layer": "Vercel auth/config",
      "meaning": "Vercel project ID for Vercel-scoped auth, not a Sajtmaskin project identifier"
    }
  },
  "lanes": {
    "preview": {
      "stateful": true,
      "key": "chatId",
      "workspaceIsolation": "live preview workspace per chat/session",
      "producesPreviewUrl": true,
      "auth": {
        "requiredOutsideLocalDev": true,
        "appEnvKey": "SAJTMASKIN_PREVIEW_HOST_API_KEY",
        "hostEnvKey": "PREVIEW_HOST_API_KEY"
      }
    },
    "verify": {
      "stateful": false,
      "key": "chatId+versionId+verifyId",
      "workspaceIsolation": "isolated temporary verify workspace",
      "producesPreviewUrl": false,
      "checks": ["typecheck", "build", "lint"],
      "manifestLaneSelection": {
        "configKey": "qualityGateTiers",
        "lanes": {
          "designPreview": {
            "checks": ["typecheck"],
            "purpose": "F2 quality gate. Used by live-preview tier-2 verification, background `server-verify` and post-repair re-check.",
            "consumer": "DESIGN_PREVIEW_QUALITY_GATE_CHECKS"
          },
          "integrationsBuild": {
            "checks": ["typecheck", "build", "lint"],
            "purpose": "F3 quality gate. Used by `/finalize-design` flow and promotion paths.",
            "consumer": "INTEGRATIONS_BUILD_QUALITY_GATE_CHECKS"
          }
        },
        "removed2026Q2": ["tier2", "serverVerify", "promotion", "interactive"]
      },
      "appSideTelemetryNote": "Sajtmaskin may attach optional compact visualQA inside persisted preflight:quality-gate log meta when SAJTMASKIN_VISUAL_QA is enabled and all verify checks passed; this is app-side only and not part of PreviewHostVerifyResponse.",
      "auth": {
        "requiredOutsideLocalDev": true,
        "appEnvKey": "SAJTMASKIN_PREVIEW_HOST_API_KEY",
        "hostEnvKey": "PREVIEW_HOST_API_KEY"
      }
    }
  },
  "contracts": {
    "PreviewSessionPostApiJson": {
      "route": "/api/engine/chats/[chatId]/preview-session",
      "type": "object",
      "required": [],
      "properties": {
        "ok": { "type": "boolean", "required": false },
        "code": { "type": "string", "required": false },
        "hint": { "type": "string", "required": false },
        "message": { "type": "string", "required": false },
        "stage": { "type": "string", "required": false },
        "failureCode": { "type": "string", "required": false },
        "retryable": { "type": "boolean", "required": false },
        "previewUrl": { "type": "string", "required": false },
        "previewSessionId": { "type": "string", "required": false },
        "previewMode": { "type": "string", "required": false },
        "previewTier": { "type": "number", "required": false },
        "prodBuildVerified": { "type": "boolean", "required": false },
        "prodBuildLogSnippet": { "type": "string", "required": false },
        "startOutcome": {
          "type": "string",
          "required": false,
          "enum": ["reused_url", "resumed", "recreated"]
        }
      }
    },
    "PreviewStatusApiJson": {
      "route": "/api/engine/chats/[chatId]/preview-status",
      "type": "object",
      "required": ["ok", "status", "previewSessionId", "previewUrl", "versionId", "sessionExpiresAt"],
      "properties": {
        "ok": { "type": "boolean", "required": true },
        "status": {
          "type": "string",
          "required": true,
          "enum": ["running", "starting", "stopped", "missing", "version_mismatch"]
        },
        "previewSessionId": { "type": ["string", "null"], "required": true },
        "previewUrl": { "type": ["string", "null"], "required": true },
        "versionId": { "type": ["string", "null"], "required": true },
        "sessionExpiresAt": { "type": ["number", "null"], "required": true },
        "reason": { "type": "string", "required": false },
        "mismatchDirection": {
          "type": "string",
          "required": false,
          "enum": ["session_newer", "session_older", "unknown"]
        },
        "message": { "type": "string", "required": false }
      }
    },
    "PreviewHeartbeatApiJson": {
      "route": "/api/engine/chats/[chatId]/preview-heartbeat",
      "type": "object",
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean", "required": true },
        "reason": { "type": "string", "required": false }
      }
    },
    "PreviewHibernateApiJson": {
      "route": "/api/engine/chats/[chatId]/preview-hibernate",
      "type": "object",
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean", "required": true },
        "hibernated": { "type": "boolean", "required": false },
        "reason": { "type": "string", "required": false },
        "message": { "type": "string", "required": false }
      }
    },
    "PreviewDestroyApiJson": {
      "route": "/api/engine/chats/[chatId]/preview-destroy",
      "type": "object",
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean", "required": true },
        "destroyed": { "type": "boolean", "required": false },
        "clearedPreviewUrl": { "type": "boolean", "required": false },
        "tier2Provider": {
          "type": ["string", "null"],
          "required": false,
          "enum": ["preview_host", null]
        },
        "reason": { "type": "string", "required": false },
        "message": { "type": "string", "required": false },
        "providerDestroyDeferred": {
          "type": "boolean",
          "required": false,
          "note": "True when local state was cleared but the host destroy returned a retryable failure (5xx). Host-side cleanup is deferred to idle TTL or `/admin/cleanup`."
        }
      }
    },
    "FinalizeDesignApiJson": {
      "route": "/api/engine/chats/[chatId]/finalize-design",
      "method": "POST",
      "purpose": "F3 ('Bygg integrationer') trigger. Validates tier-3 readiness against stored project env vars before allowing the chat-stream caller to start an F3 generation with `meta.lifecycleStage: \"integrations\"` and `meta.parentVersionId`.",
      "type": "object",
      "request": {
        "type": "object",
        "required": [],
        "properties": {
          "versionId": {
            "type": "string",
            "required": false,
            "note": "Defaults to preferred/latest engine version for the chat."
          }
        }
      },
      "responses": {
        "200_ready": {
          "required": ["ready", "parentVersionId", "streamMeta"],
          "properties": {
            "ready": { "const": true },
            "parentVersionId": { "type": "string" },
            "requirements": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["key", "name", "requiredRealEnvKeys"],
                "properties": {
                  "key": { "type": "string" },
                  "name": { "type": "string" },
                  "requiredRealEnvKeys": { "type": "array", "items": { "type": "string" } }
                }
              }
            },
            "streamMeta": {
              "type": "object",
              "required": ["lifecycleStage", "parentVersionId"],
              "properties": {
                "lifecycleStage": { "const": "integrations" },
                "parentVersionId": { "type": "string" }
              }
            }
          }
        },
        "412_missing_env": {
          "required": ["ready", "parentVersionId", "missingByIntegration"],
          "properties": {
            "ready": { "const": false },
            "parentVersionId": { "type": "string" },
            "missingByIntegration": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["key", "name", "missing"],
                "properties": {
                  "key": { "type": "string" },
                  "name": { "type": "string" },
                  "missing": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "404_not_found": { "required": ["error"] },
        "409_already_integrations": { "required": ["ready", "reason"] }
      }
    },
    "PreviewHostVerifyRequest": {
      "route": "POST /preview/verify",
      "type": "object",
      "required": ["chatId", "versionId", "filesJson"],
      "legacyAcceptedAliases": {
        "projectId": "chatId"
      },
      "properties": {
        "chatId": { "type": "string", "required": true },
        "projectId": { "type": "string", "required": false },
        "versionId": { "type": "string", "required": true },
        "filesJson": { "type": "object", "required": true },
        "checks": {
          "type": "array",
          "required": false,
          "items": {
            "type": "string",
            "enum": ["typecheck", "build", "lint"]
          }
        }
      }
    },
    "PreviewHostVerifyResponse": {
      "route": "POST /preview/verify",
      "type": "object",
      "required": ["ok", "verifyId", "chatId", "versionId", "durationMs", "results"],
      "properties": {
        "ok": { "type": "boolean", "required": true },
        "verifyId": { "type": "string", "required": true },
        "chatId": { "type": "string", "required": true },
        "versionId": { "type": "string", "required": true },
        "durationMs": { "type": "number", "required": true },
        "jobStartedAt": { "type": ["string", "null"], "required": false },
        "jobFinishedAt": { "type": ["string", "null"], "required": false },
        "firstFailureCheck": { "type": ["string", "null"], "required": false },
        "results": {
          "type": "array",
          "required": true,
          "items": {
            "type": "object",
            "required": ["check", "passed", "exitCode", "output"],
            "properties": {
              "check": { "type": "string", "required": true },
              "passed": { "type": "boolean", "required": true },
              "exitCode": { "type": "number", "required": true },
              "output": { "type": "string", "required": true },
              "durationMs": { "type": "number", "required": false }
            }
          }
        }
      }
    },
    "PreviewHostPatchRequest": {
      "route": "POST /preview/session/patch",
      "purpose": "Fast Edit Lane. Pushes only the changed files of a trivial edit into the live preview workspace; usually no Next dev restart.",
      "type": "object",
      "required": ["versionId"],
      "oneOfSessionRef": ["previewSessionId", "sessionId"],
      "legacyAcceptedAliases": {
        "sandboxId": "previewSessionId"
      },
      "properties": {
        "previewSessionId": { "type": "string", "required": false },
        "sessionId": { "type": "string", "required": false },
        "versionId": { "type": "string", "required": true },
        "files": {
          "type": "object",
          "required": false,
          "note": "Partial set of changed files (path -> content). At least one of `files` or `removedPaths` must be non-empty."
        },
        "removedPaths": {
          "type": "array",
          "required": false,
          "items": { "type": "string" }
        }
      }
    },
    "PreviewHostPatchResponse": {
      "route": "POST /preview/session/patch",
      "type": "object",
      "required": ["sessionId", "previewSessionId", "versionId", "previewUrl", "patchMode"],
      "properties": {
        "sessionId": { "type": "string", "required": true },
        "previewSessionId": { "type": "string", "required": true },
        "sandboxId": { "type": "string", "required": false, "note": "Legacy alias for previewSessionId." },
        "chatId": { "type": "string", "required": false },
        "versionId": { "type": "string", "required": true },
        "previewUrl": { "type": "string", "required": true },
        "lastAction": { "type": "string", "required": false, "const": "patch" },
        "patchMode": {
          "type": "string",
          "required": true,
          "enum": ["patched", "restarted", "booted"],
          "note": "patched=hot file write, no restart; restarted=dependency/config change forced a full boot; booted=runtime was not running."
        },
        "patchReason": { "type": ["string", "null"], "required": false }
      }
    }
  }
}
