# =============================================================================
# SAJTMASKIN .cursorignore
# =============================================================================
# Gäller bara filer INOM denna workspace. Cursor indexerar inte mappar utanför
# repot (t.ex. C:\...\vercel-scrape) — skrap/kloner dit påverkar inte indexet här.
# Stora dataset i repot (_template_refs, ev. vercel-scrape i roten) ignoreras nedan.
#
# Negation (!) fungerar bara om en tidigare rad ignorerat samma sökväg — därför
# måste huvudmönstret vara aktivt (inte kommenterat med # i början av raden).
# =============================================================================

# --- Build & cache (tunga, ändras ofta)
node_modules/
.next/
.cache/
dist/
build/
coverage/
tsconfig.tsbuildinfo

# --- Git (onödigt för kodindex)
.git/

# --- Secrets & lokal status
.env
.env.*
.env.local
.env.production
.token-status.json

# --- Lokal dev / automation-config (sällan relevant för kod)
config.txt
config.example.txt
sajtmaskin.code-workspace

# --- Stor media (hela public/ ignoreras nedan; detta fångar mp4 var som helst)
*.mp4
*.webm

# --- Agent scratch (delvis)
.j_to_agent/structure_bugs_and_parralells
.j_to_agent/analysis

# --- Sällan ändrad kod: indexera README/entrypoints, inte allt
src/components/ui/

#scripts/

# API-ytor som sällan behövs i generell sökning
#src/app/api/admin/
#src/app/api/stripe/
#src/app/api/auth/

#src/components/landing-v2/

# --- Statiska assets (stora, sällan "läs som kod")
#public/

# --- Research & mall-discovery (Zon 1 i repo + pipeline; Zon 2 JSON under research/ men README synlig)
#research/
#!research/README.md

scaffold-pipeline/
_template_refs/
_sidor/

old

# Om du någon gång lägger skrapdata i repots rot (annars tomt — skadar inte)
#vercel-scrape/
#vercel_usecase_next_react_templates/

# --- Genererade JSON/TS (byggs om; undvik brus i sök)
# Håll fullständiga sökvägar (t.ex. scaffold-research — aldrig trunkera till "s.generated.json").
#src/lib/gen/data/docs-embeddings.json
#src/lib/gen/data/docs-snippets.ts
#src/lib/gen/scaffolds/scaffold-embeddings.json
#src/lib/gen/scaffolds/scaffold-research.generated.json
#src/lib/gen/template-library/template-library-embeddings.json
#src/lib/gen/template-library/template-library.generated.json

# --- Övrigt stort / återhämtning
#world-class-recovery/

# --- MCP-dokumentation (om mappen skapas; stor cache)
#services/mpc/docs/docgrab__*/
#services/mpc/docs/local/
#services/mpc/docs/*llms*
#services/mpc/docs/shad/
#services/mpc/logs/

# --- Cursor automation & arkiv
#.cursor/automation/runs/
#.cursor/automation/archive/
#.cursor/automation/input/
.cursor/migration-archive/**

#.cursor/orchestrator/run/*/
#.cursor/orchestrator/archive/

# --- Dokumentation du medvetet gömmer från index
docs/old/**
docs/plans/archived/**

# --- Temp / legacy i roten
old/
skrapning/
ovrigt/
materials/
.preprompt_history.json

logs/
manual_log/
input_files_for_cursor/
DOM_dev_tols.txt
chat_till_vanster.txt

tests/openclaw/**
!tests/openclaw/README.md

internt_jakob/
#research/dossiers/

