# =============================================================================
# SAJTMASKIN .gitignore
# =============================================================================

# Python bytecode
__pycache__/
*.pyc

# Node/Next.js
node_modules/
.next/
out/
.cache/
dist/
build/
coverage/

# Generated files (recreated on build)
tsconfig.tsbuildinfo
next-env.d.ts

# Environment files (NEVER commit secrets!)
.env
.env.*
.env.local
*.pem
*key
.env.production
.token-status.json

# Database files (local data, not for git)
data/*.db
data/*.db-shm
data/*.db-wal
data/uploads/

# Local generated reports (recreate from scripts when needed)
data/scaffold-candidates-curated.json

# MCP scraped documentation (60+ MB, regenerate with doc.py)
services/mpc/docs/docgrab__*/
services/mpc/docs/local/
services/mpc/docs/*llms*
services/mpc/docs/SDK_6.md
services/mpc/docs/shad/
services/mpc/logs/

# Editor/OS
.idea/
.DS_Store
Thumbs.db
# Cursor-specific (plans are session-specific, mcp.json is shared)
.cursor/plans/
.cursor/documents/

# Local Cursor orchestration artifacts
.cursor/orchestrator/run/**
!.cursor/orchestrator/run/
!.cursor/orchestrator/run/README.md
.cursor/orchestrator/archive/
.cursor/control-agent/run/**
!.cursor/control-agent/run/
!.cursor/control-agent/run/README.md
.cursor/control-agent/archive/
.cursor/agent-intents/BOARD.md
.cursor/automation/runs/**
.cursor/automation/archive/**
.cursor/automation/input/**

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
mcp-monitoring-report.txt
logs/
manual_log/
input_files_for_cursor/logg_*.txt
DOM_dev_tols.txt
chat_till_vanster.txt

# Temp/dev files
.preprompt_history.json
övrigt
skrapning
/[{]*.png
_env.production
_env.development

# Avoid accidentally committing a nested clone/repo
sajtgen
_template_refs/

# Large local docs/specs (keep out of git unless intentionally added)
SiteStudio_Projektspecifikation_ifillningsbar_v2.pdf
Arkitektur och teknikstack.pdf
ANALYS-*.txt
next_sidan_skrapning.txt

# Local env dumps (often contain secrets)
environments.production
vercel-env-deploy.txt
git_env.txt
OLD_ENV_KEYS.txt

# Local agent scratch (notes); canonical copies live under docs/ when promoted
.j_to_agent/

/old/
senaste_miljovariablar/
sajtmaskin.code-workspace

# Archived secret dumps should never be versioned
docs/old/**/*.env.local
docs/old/**/*.env.production
docs/old/**/*.env
docs/old/**/*env*.txt

# Automation kit (local-only)
automation/
.automation/
.cursor-gpt-kit/
config.txt
config.browser.txt
config.example.txt
INSTALERA.py
INSTALLERA.py

# Vercel
.vercel



# >>> cursor-gpt automation local artifacts >>>
!.cursor/agents/
.cursor/agents/**
!.cursor/agents/workstream-sentry.md
.cursor/rules/automation-safety.mdc
automation/
config.txt
config.example.txt
config.browser.txt
INSTALLERA.py
INSTALERA.py
.cursor-gpt-kit/
.automation/
automation/state/run-state.json
automation/state/ui-dashboard/
automation/inbox/deep-research-report*.md
automation/inbox/tmp-*
automation/runtime/browser-input-*.md
automation/packets/iteration-*/
automation/reports/iteration-*/
automation/reports/browser-run-iteration-*.json
automation/reports/final-summary.md
automation/reports/final-summary.json
playwright-report/
test-results/
node_modules/
_scaffold_discovery/

# Scaffold pipeline — discovery, dossiers, catalog
scaffold-pipeline/discovery/**
!scaffold-pipeline/discovery/README.md
!scaffold-pipeline/discovery/SCHEMA.md
!scaffold-pipeline/discovery/schema.summary.json
scaffold-pipeline/repo-cache/**
!scaffold-pipeline/repo-cache/README.md
scaffold-pipeline/dossiers/**
!scaffold-pipeline/dossiers/*/manifest.json
!scaffold-pipeline/dossiers/*/summary.md
scaffold-pipeline/catalog/**
!scaffold-pipeline/catalog/README.md
!scaffold-pipeline/catalog/catalog.md
!scaffold-pipeline/catalog/schema.template-manifest.json
!scaffold-pipeline/catalog/EVALUATION_CHECKLIST.md
!scaffold-pipeline/catalog/PROMOTION_WORKFLOW.md
scaffold-pipeline/scripts/**
!scaffold-pipeline/scripts/scaffold-pipeline.py

# Legacy research paths (kept for backward compat, entire tree ignored)
research/
vercel_usecase_next_react_templates/
_template_refs/
_sidor/
_input_for_cursor/
