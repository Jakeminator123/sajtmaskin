      "key": "OPENAI_API_KEY",
      "required": true,
      "purpose": "Create an OpenAI API key at https://platform.openai.com/account/api-keys"
    },
    {
      "key": "OPENAI_ASSISTANT_ID",
      "required": true,
      "purpose": "IMPORTANT! Be sure to enable file search and code interpreter tools."
    }
  ],
