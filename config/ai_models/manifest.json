  "buildProfiles": {
    "defaults": {
      "fast": "gpt-5.4-mini",
      "pro": "gpt-5.3-codex",
      "max": "gpt-5.5",
      "codex": "gpt-5.3-codex",
      "anthropic": "claude-opus-4.8"
    },
    "envKeys": {
      "fast": "SAJTMASKIN_MODEL_FAST",
      "pro": "SAJTMASKIN_MODEL_PRO",
      "max": "SAJTMASKIN_MODEL_MAX",
      "codex": "SAJTMASKIN_MODEL_CODEX",
      "anthropic": "SAJTMASKIN_MODEL_ANTHROPIC"
    }
  },
  "qualityToOwnEngineModel": {
    "light": "gpt-5.4-mini",
    "standard": "gpt-5.3-codex",
    "pro": "gpt-5.3-codex",
    "premium": "gpt-5.5",
    "max": "gpt-5.3-codex"
  },
  "promptAssist": {
    "defaults": {
      "assist": "openai/gpt-5.5",
      "polish": "openai/gpt-5.3-codex"
    },
    "envKeys": {
      "assist": "SAJTMASKIN_ASSIST_MODEL",
      "polish": "SAJTMASKIN_POLISH_MODEL"
    },
    "allowed": {
      "gatewayClassModels": [
        "openai/gpt-5.5",
        "openai/gpt-5.4",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.2",
        "anthropic/claude-opus-4.8",
        "anthropic/claude-opus-4.6"
      ],
      "anthropicDirectModels": [
        "anthropic-direct/claude-haiku-4-5-20251001",
        "anthropic-direct/claude-opus-4-8",
        "anthropic-direct/claude-opus-4-6"
      ],
      "models": [
        "openai/gpt-5.5",
        "openai/gpt-5.4",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.2",
        "anthropic/claude-opus-4.8",
        "anthropic/claude-opus-4.6",
        "anthropic-direct/claude-haiku-4-5-20251001",
        "anthropic-direct/claude-opus-4-8",
        "anthropic-direct/claude-opus-4-6"
      ]
    },
    "notes": "Provider id \"gateway\" in api/ai/chat means OpenAI-class assist models; the route calls createDirectModel() which uses OPENAI_API_KEY for openai/* and ANTHROPIC_API_KEY for anthropic/*. Back-compat (MB-1): openai/gpt-5.4, anthropic/claude-opus-4.6 and anthropic-direct/claude-opus-4-6 are retained alongside the GPT-5.5 / Opus-4.8 ids from #221 so persisted/env values selected before the bump keep passing isPromptAssistModelAllowed() instead of 400-ing /api/ai/chat and /api/ai/brief. Sonnet 4.6 was retired 2026-06-28 and removed from the allow-list; any persisted anthropic/claude-sonnet-4.6 or anthropic-direct/claude-sonnet-4-6 value is silently aliased to the Opus-4.8 equivalent by aliasRetiredModelId() (src/lib/models/catalog.ts) before the allow-check, so it still passes without re-introducing Sonnet."
  },
  "briefing": {
    "defaults": {
      "requestModel": "openai/gpt-5.5",
      "serverAutoOpenAI": "openai/gpt-5.5",
      "serverAutoAnthropic": "anthropic/claude-opus-4.8"
    },
    "envKeys": {
      "requestModel": "SAJTMASKIN_BRIEF_MODEL",
      "serverAutoOpenAI": "SAJTMASKIN_AUTO_BRIEF_MODEL_OPENAI",
      "serverAutoAnthropic": "SAJTMASKIN_AUTO_BRIEF_MODEL_ANTHROPIC"
    },
    "notes": "Structured pre-build helpers. requestModel is the default for /api/ai/brief. serverAuto* control create-chat fallback when the client did not already send a brief."
  },
  "phaseRouting": {
    "defaultByTier": {
      "fast": {
        "planner": "selected_build_model",
        "generator": "selected_build_model",
        "fixer": "selected_build_model",
        "verifier": "selected_build_model",
        "deploy-assistant": "selected_build_model"
      },
      "pro": {
        "planner": "gpt-5.3-codex",
        "generator": "gpt-5.3-codex",
        "fixer": "selected_build_model",
        "verifier": "gpt-5.3-codex",
        "deploy-assistant": "gpt-5.3-codex"
      },
      "max": {
        "planner": "selected_build_model",
        "generator": "selected_build_model",
        "fixer": "gpt-5.3-codex",
        "verifier": "gpt-5.3-codex",
        "deploy-assistant": "gpt-5.3-codex"
      },
      "codex": {
        "planner": "selected_build_model",
        "generator": "selected_build_model",
        "fixer": "selected_build_model",
        "verifier": "gpt-5.3-codex",
        "deploy-assistant": "gpt-5.3-codex"
      },
      "anthropic": {
        "planner": "claude-opus-4.8",
        "generator": "claude-opus-4.8",
        "fixer": "selected_build_model",
        "verifier": "selected_build_model",
        "deploy-assistant": "claude-opus-4.8"
      }
    },
    "thinkingByTier": {
      "fast": {
        "planner": {
          "thinking": true,
          "reasoningEffort": "low"
        },
        "generator": {
          "thinking": true,
          "reasoningEffort": "medium"
        },
        "fixer": {
          "thinking": false,
          "reasoningEffort": "medium"
        },
        "verifier": {
          "thinking": false,
          "reasoningEffort": "medium"
        },
        "deploy-assistant": {
          "thinking": false,
          "reasoningEffort": "medium"
        }
      },
      "pro": {
        "planner": {
          "thinking": true,
          "reasoningEffort": "high"
        },
        "generator": {
          "thinking": true,
          "reasoningEffort": "high"
        },
        "fixer": {
          "thinking": false,
          "reasoningEffort": "medium"
        },
        "verifier": {
          "thinking": false,
          "reasoningEffort": "medium"
        },
        "deploy-assistant": {
          "thinking": false,
          "reasoningEffort": "medium"
        }
      },
      "max": {
        "planner": {
          "thinking": true,
          "reasoningEffort": "high"
        },
        "generator": {
          "thinking": true,
          "reasoningEffort": "high"
        },
        "fixer": {
          "thinking": false,
          "reasoningEffort": "medium"
        },
        "verifier": {
          "thinking": false,
          "reasoningEffort": "medium"
        },
        "deploy-assistant": {
          "thinking": false,
          "reasoningEffort": "medium"
        }
      },
      "codex": {
        "planner": {
          "thinking": true,
          "reasoningEffort": "high"
        },
        "generator": {
          "thinking": true,
          "reasoningEffort": "high"
        },
        "fixer": {
          "thinking": false,
          "reasoningEffort": "medium"
        },
        "verifier": {
          "thinking": false,
          "reasoningEffort": "medium"
        },
        "deploy-assistant": {
          "thinking": false,
          "reasoningEffort": "medium"
        }
      },
      "anthropic": {
        "planner": {
          "thinking": true,
          "reasoningEffort": "high"
        },
        "generator": {
          "thinking": true,
          "reasoningEffort": "high"
        },
        "fixer": {
          "thinking": false,
          "reasoningEffort": "medium"
        },
        "verifier": {
          "thinking": false,
          "reasoningEffort": "medium"
        },
        "deploy-assistant": {
          "thinking": false,
          "reasoningEffort": "medium"
        }
      }
    },
    "notes": "selected_build_model means: follow the resolved build profile model from buildProfiles/defaults or env override. MB-3 (fixed 2026-06-23): the own-engine generation stream now routes the `generator` phase through resolvePhaseModel() — the codegen call (pipeline.model) plus the SSE/version telemetry model use resolvePhaseModel(tier, 'generator').modelId in create-chat-stream-post.ts, chat-message-stream-post.ts and generate-site-from-prompt.ts. On the `anthropic` tier codegen therefore runs on the declared generator `claude-opus-4.8`; for every other tier in the default config the generator model equals buildProfiles.defaults[tier] so behavior is unchanged. The persisted `chat.model` deliberately stays the tier build model (resolveEngineModelId(tier)) so the repair route and background server-verify can round-trip the tier from it via ownModelIdToCanonicalModelId(); only the generated version's telemetry model reflects the per-phase generator model. planner (plan mode), verifier, fixer and deploy-assistant continue to consume resolvePhaseModel() as before. Sonnet 4.6 retired 2026-06-28: the anthropic tier now runs Opus 4.8 across every phase (deploy-assistant switched from Sonnet to Opus); fixer + verifier thinking is disabled (thinking:false) to contain Opus cost on the low-reasoning phases."
  },
