  "preGenerationContracts": {
    "defaults": {
      "fallbackDatabaseProvider": "SQLite",
      "fallbackAuthProvider": "NextAuth / Auth.js",
      "fallbackPaymentProvider": "Stripe"
    },
    "providerRules": [
      {
        "kind": "database",
        "provider": "Supabase",
        "name": "Supabase",
        "envVars": [
          "NEXT_PUBLIC_SUPABASE_URL",
          "NEXT_PUBLIC_SUPABASE_ANON_KEY"
        ],
        "matchPatterns": [
          "\\bsupabase\\b"
        ],
        "reason": "Prompten nämner Supabase eller ett tydligt Supabase-flöde."
      },
      {
        "kind": "database",
        "provider": "Prisma",
        "name": "Prisma",
        "envVars": [
          "DATABASE_URL"
        ],
        "matchPatterns": [
          "\\bprisma\\b"
        ],
        "reason": "Prompten nämner Prisma uttryckligen."
      },
      {
        "kind": "database",
        "provider": "Drizzle",
        "name": "Drizzle",
        "envVars": [
          "DATABASE_URL"
        ],
        "matchPatterns": [
          "\\bdrizzle\\b"
        ],
        "reason": "Prompten nämner Drizzle uttryckligen."
      },
      {
        "kind": "database",
        "provider": "SQLite",
        "name": "SQLite",
        "envVars": [
          "DATABASE_URL"
        ],
        "matchPatterns": [
          "\\bsqlite\\b",
          "\\bbetter-sqlite3\\b"
