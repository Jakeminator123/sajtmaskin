{
  "name": "sajtmaskin-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.14.0 <23"
  },
  "volta": {
    "node": "22.22.2"
  },
  "scripts": {
    "preflight:common": "node scripts/dev/check-systemprompt.mjs && node scripts/dev/check-lucide-icons.mjs && node scripts/dev/check-unicode-regex.mjs && node scripts/dev/check-autofix-load.mjs && node scripts/dev/check-bug-backlog.mjs",
    "check:terms": "node scripts/dev/check-term-coverage.mjs",
    "db:schema-drift": "vitest run src/lib/db/schema-drift.test.ts",
    "db:schema-drift:soft": "npm run db:schema-drift || echo [db:schema-drift] WARN: schema-drift mellan src/lib/db/schema.ts och scripts/db/db-init.mjs / add-performance-indexes.mjs - se output ovan. Dev startar anda.",
    "predev": "node scripts/dev/predev.mjs",
    "dev": "node scripts/dev/next-runner.mjs dev",
    "dev:clean": "node scripts/dev/clean-next-cache.mjs && npm run dev",
    "clean:orphans": "node scripts/dev/clean-orphans.mjs",
    "clean:orphans:dry": "node scripts/dev/clean-orphans.mjs --dry-run",
    "dev:unlock": "node scripts/dev/unlock-dev.mjs",
    "dev:fast": "node scripts/dev/dev-fast.mjs",
    "refresh-token": "node scripts/dev/refresh-token.mjs",
    "prebuild": "npm run preflight:common && npm run scaffolds:embeddings:check",
    "build": "node scripts/dev/next-runner.mjs build",
    "start": "node scripts/dev/next-runner.mjs start",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "lint:fix": "eslint . --cache --cache-location .eslintcache --fix",
    "lint:watch": "npx nodemon --ext ts,tsx,js,jsx --exec \"eslint . --cache --cache-location .eslintcache --fix\"",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "devtest": "npm run typecheck && npm run scaffolds:validate && npm run dossiers:validate-all && npm run test:ci && npm run lint",
    "db:init": "node scripts/db/db-init.mjs",
    "db:init:soft": "node scripts/db/db-init.mjs || echo [db:init] WARN: skipped (DB unreachable) - dev continues",
    "db:check": "node scripts/db/check-dev-db.mjs",
    "db:rows": "node scripts/db/db-row-overview.mjs",
    "db:latest": "node scripts/db/latest-site.mjs",
    "db:health": "node scripts/db/db-health-check.mjs",
    "db:perf-indexes": "node scripts/db/add-performance-indexes.mjs",
    "db:perf-indexes:dry": "node scripts/db/add-performance-indexes.mjs --dry-run",
    "db:perf-indexes:soft": "node scripts/db/add-performance-indexes.mjs --reason auto:predev || echo [db:perf-indexes] Soft-skipped (se data/observability/db-perf-indexes-runs.ndjson)",
    "db:drop-legacy-aliases": "node scripts/db/drop-legacy-index-aliases.mjs",
    "db:drop-legacy-aliases:apply": "node scripts/db/drop-legacy-index-aliases.mjs --apply",
    "redis:health": "node scripts/db/redis-health-check.mjs",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:stability": "npm run db:schema-drift && vitest run --passWithNoTests -c vitest.stability.config.ts",
    "test:followup-contract": "vitest run -c vitest.stability.config.ts src/lib/gen/followup-freeze.stability.test.ts src/lib/gen/followup-capabilities.stability.test.ts",
    "test:focused": "vitest run src/components/builder/BuilderMessageTooling.test.tsx src/lib/hooks/chat/helpers.test.ts src/lib/hooks/chat/post-checks.test.ts src/lib/hooks/chat/stream-handlers.test.ts src/lib/gen/stream/finalize-version.test.ts src/lib/gen/post-process/image-materializer.test.ts src/lib/gen/verify/preview-quality-gate.test.ts src/lib/gen/verify/server-verify.test.ts src/lib/providers/own-engine/generation-stream-post-finalize.test.ts src/lib/gen/eval/runner.test.ts src/lib/gen/eval/baseline.test.ts src/lib/gen/eval/scorecard.test.ts src/app/api/engine/chats/[chatId]/quality-gate/route.test.ts src/lib/integrations/tier3-build-spec.test.ts src/lib/gen/preview/warm-typecheck.test.ts src/lib/gen/autofix/rules/tier3-sdk-guard-fixer.test.ts",
    "test:deploy-smoke:e2e": "playwright test -c playwright.deploy-smoke.config.ts",
    "templates:sync": "node scripts/v0-templates/sync-v0-templates.mjs",
    "templates:validate": "node scripts/v0-templates/validate-templates.mjs",
    "templates:refresh": "node scripts/v0-templates/sync-v0-templates.mjs && node scripts/v0-templates/validate-templates.mjs",
    "templates:local:refresh": "node scripts/v0-templates/refresh-local-v0-catalog.mjs",
    "templates:local:refresh:embeddings": "node scripts/v0-templates/refresh-local-v0-catalog.mjs --with-embeddings",
    "templates:blob:sync": "node scripts/v0-templates/sync-blob-catalog.mjs",
    "templates:embeddings": "npx tsx scripts/embeddings/generate-template-embeddings.ts",
    "scaffolds:embeddings": "npx tsx scripts/embeddings/generate-scaffold-embeddings.ts",
    "scaffolds:embeddings:check": "npx tsx scripts/embeddings/check-scaffold-embeddings.ts",
    "backoffice": "node scripts/dev/run-python.mjs sajtmaskin_backoffice.py",
    "canvas:open": "node scripts/canvas/open-in-browser.mjs",
    "inspector:start": "node services/inspector-worker/server.mjs",
    "inspector:install": "cd services/inspector-worker && npm install && npx playwright install chromium",
    "inspector:health": "curl -sf http://localhost:3310/health || echo UNHEALTHY",
    "inspector:docker:up": "docker compose -f infra/inspector-worker/docker-compose.yml up -d --build",
    "inspector:docker:down": "docker compose -f infra/inspector-worker/docker-compose.yml down",
    "inspector:docker:logs": "docker compose -f infra/inspector-worker/docker-compose.yml logs -f inspector-worker",
    "inspector:docker:ps": "docker compose -f infra/inspector-worker/docker-compose.yml ps",
    "scaffolds:variant-embeddings": "npx tsx scripts/scaffolds/generate-variant-embeddings.ts",
    "scaffolds:variant-patterns": "npx tsx scripts/scaffolds/auto-curate-variant-patterns.ts",
    "scaffolds:variant-patterns:dry": "npx tsx scripts/scaffolds/auto-curate-variant-patterns.ts --dry-run",
    "scaffolds:validate": "npx vitest run src/lib/gen/scaffolds/scaffold-manifest-validation.test.ts",
    "dossiers:curate": "npx tsx scripts/dossiers/curate-from-reference.ts",
    "dossiers:capability-map:check": "npx tsx scripts/dossiers/regenerate-capability-map.ts",
    "dossiers:capability-map:write": "npx tsx scripts/dossiers/regenerate-capability-map.ts --write",
    "dossiers:validate-all": "npx tsx scripts/dossiers/validate-all.ts",
    "control-plane:check": "node scripts/control-plane/check-registry.mjs",
    "shadcn:sync": "npx tsx scripts/shadcn/sync-shadcn-registry.ts",
    "shadcn:sync:soft": "npm run shadcn:sync || echo [shadcn-sync] Registry check skipped",
    "shadcn:sync:write": "npx tsx scripts/shadcn/sync-shadcn-registry.ts --write",
    "plans:archive": "node scripts/plans/auto-archive.mjs",
    "plans:archive:apply": "node scripts/plans/auto-archive.mjs --apply",
    "typography:validate-pairings": "npx tsx scripts/typography/validate-font-pairings.ts",
    "baseline-deps:verify": "npx tsx scripts/deps/validate-baseline-npm-versions.ts",
    "baseline-deps:tree": "npx tsx scripts/deps/validate-baseline-npm-tree.ts",
    "eval": "npx tsx scripts/eval/run-eval.ts",
    "scaffolds:eval": "npx tsx scripts/scaffolds/eval-scaffold-selection.ts",
    "eval:followup": "npx tsx src/lib/gen/eval/follow-up-context-cli.ts",
    "eval:post-generation": "npm run eval:followup",
    "eval:before-prompt-change": "npm run eval:followup && npm run eval:weird-smoke",
    "eval:suite": "npx tsx src/lib/gen/eval/cli.ts",
    "eval:smoke": "npx tsx src/lib/gen/eval/cli.ts --smoke",
    "eval:weird-smoke": "npx tsx src/lib/gen/eval/cli.ts --prompts=realtor-multipage,dog-daycare,arcade-with-klarna",
    "eval:weird-smoke:dump": "npx tsx src/lib/gen/eval/cli.ts --prompts=realtor-multipage,dog-daycare,arcade-with-klarna --dump-files",
    "eval:gate": "npx tsx src/lib/gen/eval/cli.ts --gate",
    "eval:baseline": "npx tsx src/lib/gen/eval/cli.ts --gate --save-baseline",
    "db:migrate": "npx tsx scripts/db/run-migrations.ts",
    "db:push": "node scripts/db/db-push.mjs",
    "db:generate": "npx drizzle-kit generate",
    "vercel:link": "vercel link",
    "env:status": "node scripts/dev/run-python.mjs scripts/env/manage_env.py status",
    "env:audit": "node scripts/dev/run-python.mjs scripts/env/manage_env.py audit",
    "env:audit:strict": "node scripts/dev/run-python.mjs scripts/env/manage_env.py audit --strict",
    "env:reconcile": "node scripts/dev/run-python.mjs scripts/env/manage_env.py reconcile",
    "env:pull": "vercel env pull .env.local --yes",
    "env:pull:prod-snapshot": "vercel env pull .env.vercel.production.pulled --environment production --yes",
    "mirror:audit": "node scripts/audit/audit-shadcn-mirror-repos.mjs",
    "mirror:audit:verbose": "node scripts/audit/audit-shadcn-mirror-repos.mjs --verbose",
    "mirror:audit:json": "node scripts/audit/audit-shadcn-mirror-repos.mjs --json",
    "mirror:audit:strict": "node scripts/audit/audit-shadcn-mirror-repos.mjs --strict",
    "rag:error-log:reindex": "node scripts/observability/index-error-log-rag.mjs",
    "rag:error-log:reindex:force": "node scripts/observability/index-error-log-rag.mjs --force",
    "fixers:dump": "node scripts/observability/dump-fixer-registry.mjs",
    "faults:report": "node scripts/observability/report-fault-promotion-candidates.mjs",
    "observability:rebuild-all": "npm run rag:error-log:reindex:force && npm run fixers:dump",
    "provision:warm-cache": "npx tsx scripts/provision-warm-cache.ts",
    "provision:warm-cache:force": "npx tsx scripts/provision-warm-cache.ts --force"
  },
